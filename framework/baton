        isinstance(entry, dict) and entry.get("event") == "created"
        for entry in history
    )


def archive_companion_ids(directory, suffix):
    ids = set()
    if not os.path.isdir(directory):
        return ids
    for name in os.listdir(directory):
        if suffix and not name.endswith(suffix):
            continue
        task_id = name[:-len(suffix)] if suffix else name
        if archive_task_id_is_valid(task_id):
            ids.add(task_id)
    return ids


def archive_layout_problems(baton_dir, active, archived):
    """Return read-only diagnostics for pending, split, and orphaned archives."""
    problems = []
    journal = archive_transaction_path(baton_dir)
    if os.path.lexists(journal):
        problems.append(
            "archive transaction is pending at {}; run 'baton archive' to recover"
            .format(journal)
        )

    active_by_id = {
        task.get("id"): task for task in active
        if archive_task_id_is_valid(task.get("id"))
    }
    archived_by_id = {
        task.get("id"): task for task in archived
        if archive_task_id_is_valid(task.get("id"))
    }
    active_ids = set(active_by_id)
    archived_ids = set(archived_by_id)
    active_markdown = archive_companion_ids(tasks_dir(baton_dir), ".md")
    active_work = archive_companion_ids(work_dir(baton_dir), "")
    archived_markdown = archive_companion_ids(archive_dir(baton_dir), ".md")
    archived_work = archive_companion_ids(archive_dir(baton_dir), ".work")

    companion_groups = (
        (active_markdown, tasks_dir(baton_dir), ".md", stat.S_ISREG, "task spec"),
        (active_work, work_dir(baton_dir), "", stat.S_ISDIR, "work"),
        (archived_markdown, archive_dir(baton_dir), ".md", stat.S_ISREG,
         "archived task spec"),
        (archived_work, archive_dir(baton_dir), ".work", stat.S_ISDIR,
         "archived work"),
    )
    for task_ids, directory, suffix, expected_type, label in companion_groups:
        for task_id in sorted(task_ids):
            path = os.path.join(directory, task_id + suffix)
            try:
                path_stat = os.lstat(path)
            except OSError as error:
                problems.append("{}: cannot inspect {}: {}".format(task_id, label, error))
            else:
                if not expected_type(path_stat.st_mode):
                    problems.append("{}: {} has an unexpected type".format(task_id, label))

    for task_id in sorted(active_ids & (archived_markdown | archived_work)):
        problems.append(
            "{}: active task state has archived companion artifacts".format(task_id)
        )
    for task_id in sorted(archived_ids & (active_markdown | active_work)):
        problems.append(
            "{}: archived task state has active companion artifacts".format(task_id)
        )
    for task_id in sorted(active_markdown - active_ids):
        problems.append(
            "{}: active task spec has no corresponding active state".format(task_id)
        )
    for task_id in sorted(active_work - active_ids):
        problems.append(
            "{}: active work has no corresponding active state".format(task_id)
        )
    for task_id in sorted(archived_markdown - archived_ids):
        problems.append(
            "{}: archived task spec has no corresponding archived state".format(task_id)
        )
    for task_id in sorted(archived_work - archived_ids):
        problems.append(
            "{}: archived work has no corresponding archived state".format(task_id)
        )
    for task_id, task in sorted(archived_by_id.items()):
        if task_requires_spec_artifact(task) and task_id not in archived_markdown:
            problems.append("{}: archived task spec is missing".format(task_id))
        if task_requires_work_artifact(task) and task_id not in archived_work:
            problems.append("{}: required archived work is missing".format(task_id))
    for task_id, task in sorted(active_by_id.items()):
        if task_requires_work_artifact(task) and task_id not in active_work:
            problems.append("{}: required active work is missing".format(task_id))
    return problems


def archive_artifact(task_id, source, destination, kind):
    return {
        "task_id": task_id,
        "source": source,
        "destination": destination,
        "kind": kind,
    }


def archive_artifact_path(baton_dir, relative_path):
    return os.path.join(baton_dir, *relative_path.split("/"))


def require_archive_artifact_type(path, kind, required=False):
    try:
        path_stat = os.lstat(path)
    except FileNotFoundError:
        if required:
            raise ValueError("required archive artifact is missing: {}".format(path))
        return False
    if stat.S_ISLNK(path_stat.st_mode):
        raise ValueError("archive transaction artifact is a symlink: {}".format(path))
    expected = stat.S_ISREG if kind == "file" else stat.S_ISDIR
    if not expected(path_stat.st_mode):
        raise ValueError(
            "archive transaction artifact has unexpected type: {}".format(path)
        )
    return True


def build_archive_transaction(baton_dir, tasks):
    artifacts = []
    task_ids = []
    for task in tasks:
        task_id = task["id"]
        task_ids.append(task_id)
        entries = (
            archive_artifact(
                task_id, "tasks/" + task_id + ".json",
                "archive/" + task_id + ".json", "file",
            ),
            archive_artifact(
                task_id, "tasks/" + task_id + ".md",
                "archive/" + task_id + ".md", "file",
            ),
        )
        for artifact in entries:
            source = archive_artifact_path(baton_dir, artifact["source"])
            require_archive_artifact_type(source, artifact["kind"], required=True)
            artifacts.append(artifact)
        source_work = work_dir(baton_dir, task_id)
        if os.path.lexists(source_work):
            require_archive_artifact_type(source_work, "directory", required=True)
            artifacts.append(archive_artifact(
                task_id, "work/" + task_id,
                "archive/" + task_id + ".work", "directory",
            ))
        elif task_requires_work_artifact(task):
            raise ValueError(
                "cannot archive {}: required work artifact is missing".format(task_id)
            )
    transaction = {"version": 1, "tasks": task_ids, "artifacts": artifacts}
    validate_archive_transaction(transaction)
    for artifact in artifacts:
        destination = archive_artifact_path(baton_dir, artifact["destination"])
        if os.path.lexists(destination):
            raise ValueError("archive destination already exists: {}".format(destination))
    return transaction


def validate_archive_transaction(transaction):
    problem = "archive transaction journal is invalid"
    if not isinstance(transaction, dict) or set(transaction) != {
            "version", "tasks", "artifacts"}:
        raise ValueError(problem + ": unexpected top-level shape")
    if type(transaction["version"]) is not int or transaction["version"] != 1:
        raise ValueError(problem + ": unsupported version")
    task_ids = transaction["tasks"]
    artifacts = transaction["artifacts"]
    if (
            not isinstance(task_ids, list) or not task_ids
            or any(not archive_task_id_is_valid(item) for item in task_ids)
            or len(task_ids) != len(set(task_ids))):
        raise ValueError(problem + ": task list is missing or invalid")
    if not isinstance(artifacts, list) or not artifacts:
        raise ValueError(problem + ": artifact list is missing or invalid")
    required_by_task = {
        task_id: {
            ("tasks/" + task_id + ".json", "archive/" + task_id + ".json", "file"),
            ("tasks/" + task_id + ".md", "archive/" + task_id + ".md", "file"),
        }
        for task_id in task_ids
    }
    seen = set()
    for artifact in artifacts:
        if not isinstance(artifact, dict) or set(artifact) != {
                "task_id", "source", "destination", "kind"}:
            raise ValueError(problem + ": artifact entry has an unexpected shape")
        task_id = artifact["task_id"]
        triple = (
            artifact["source"], artifact["destination"], artifact["kind"],
        )
        allowed = required_by_task.get(task_id, set()) | ({
            ("work/" + task_id, "archive/" + task_id + ".work", "directory")
        } if task_id in required_by_task else set())
        if triple not in allowed:
            raise ValueError(problem + ": artifact paths are not trusted")
        key = (task_id,) + triple
        if key in seen:
            raise ValueError(problem + ": duplicate artifact entry")
        seen.add(key)
    for task_id, required in required_by_task.items():
        present = {item[1:] for item in seen if item[0] == task_id}
        if not required.issubset(present):
            raise ValueError(problem + ": required task artifacts are missing")
    return transaction


def read_archive_transaction(baton_dir):
    journal = archive_transaction_path(baton_dir)
    try:
        transaction = read_json(journal)
    except (OSError, UnicodeDecodeError, json.JSONDecodeError) as error:
        raise ValueError(
            "cannot recover pending archive transaction at {}: {}"
            .format(journal, error)
        ) from error
    try:
        return validate_archive_transaction(transaction)
    except ValueError as error:
        raise ValueError(
            "cannot recover pending archive transaction at {}: {}"
            .format(journal, error)
        ) from error


def archive_artifact_state(baton_dir, artifact):
    source = archive_artifact_path(baton_dir, artifact["source"])
    destination = archive_artifact_path(baton_dir, artifact["destination"])
    source_exists = require_archive_artifact_type(source, artifact["kind"])
    destination_exists = require_archive_artifact_type(destination, artifact["kind"])
    if source_exists == destination_exists:
        detail = "both source and destination exist" if source_exists else (
            "neither source nor destination exists"
        )
        raise ValueError(
            "archive transaction is ambiguous for {}: {}; journal preserved at {}"
            .format(artifact["task_id"], detail, archive_transaction_path(baton_dir))
        )
    return source, destination, source_exists


def archive_transaction_task(baton_dir, transaction, task_id):
    """Load one transaction task from its unique, trusted JSON location."""
    artifact = next(
        artifact for artifact in transaction["artifacts"]
        if artifact["task_id"] == task_id
        and artifact["source"] == "tasks/" + task_id + ".json"
    )
    source, destination, source_exists = archive_artifact_state(baton_dir, artifact)
    path = source if source_exists else destination
    try:
        task = require_loaded_task_shape(
            read_json(path), path, validate_history_fields=True,
        )
    except (OSError, UnicodeDecodeError, json.JSONDecodeError, ValueError) as error:
        raise ValueError(
            "archive transaction task state is invalid for {} at {}: {}; "
            "journal preserved at {}".format(
                task_id, path, error, archive_transaction_path(baton_dir),
            )
        ) from error
    if task.get("id") != task_id:
        raise ValueError(
            "archive transaction task identity is invalid for {} at {}; "
            "journal preserved at {}".format(
                task_id, path, archive_transaction_path(baton_dir),
            )
        )
    if task.get("status") not in ("done", "cancelled"):
        raise ValueError(
            "archive transaction task lifecycle is invalid for {} at {}; "
            "journal preserved at {}".format(
                task_id, path, archive_transaction_path(baton_dir),
            )
        )
    return task


def validate_archive_transaction_topology(baton_dir, transaction):
    """Reject journal work entries that disagree with the preserved topology."""
    journal = archive_transaction_path(baton_dir)
    work_task_ids = {
        artifact["task_id"] for artifact in transaction["artifacts"]
        if artifact["kind"] == "directory"
    }
    for task_id in transaction["tasks"]:
        task = archive_transaction_task(baton_dir, transaction, task_id)
        active_path = work_dir(baton_dir, task_id)
        archived_path = os.path.join(archive_dir(baton_dir), task_id + ".work")
        active_exists = require_archive_artifact_type(active_path, "directory")
        archived_exists = require_archive_artifact_type(archived_path, "directory")
        if active_exists and archived_exists:
            detail = "both active and archived work exist"
        elif task_requires_work_artifact(task) and task_id not in work_task_ids:
            detail = (
                "the canonical work artifact entry is missing"
                if active_exists or archived_exists else
                "the canonical required work artifact entry is missing"
            )
        elif task_requires_work_artifact(task) and not (
                active_exists or archived_exists):
            detail = "the required work artifact is missing"
        elif active_exists or archived_exists:
            if task_id in work_task_ids:
                continue
            detail = "the canonical work artifact entry is missing"
        elif task_id in work_task_ids:
            detail = "the work artifact entry has no active or archived work"
        else:
            continue
        raise ValueError(
            "archive transaction work topology is invalid for {}: {}; "
            "journal preserved at {}".format(task_id, detail, journal)
        )


def bind_atomic_archive_rename(platform_name, library):
    """Bind the platform's atomic no-replace rename and return its call shape."""
    if platform_name.startswith("linux"):
        try:
            operation = library.renameat2
        except AttributeError:
            return None, "libc renameat2 is unavailable"
        operation.argtypes = (
            ctypes.c_int, ctypes.c_char_p, ctypes.c_int, ctypes.c_char_p,
            ctypes.c_uint,
        )
        operation.restype = ctypes.c_int

        def rename_no_replace(source, destination):
            return operation(-100, source, -100, destination, 1)

        return rename_no_replace, "renameat2(RENAME_NOREPLACE)"
    if platform_name == "darwin":
        try:
            operation = library.renamex_np
        except AttributeError:
            return None, "libc renamex_np is unavailable"
        operation.argtypes = (ctypes.c_char_p, ctypes.c_char_p, ctypes.c_uint)
        operation.restype = ctypes.c_int

        def rename_no_replace(source, destination):
            return operation(source, destination, 0x00000004)

        return rename_no_replace, "renamex_np(RENAME_EXCL)"
    return None, "unsupported operating system {}".format(platform_name)


try:
    ATOMIC_ARCHIVE_RENAME_LIBRARY = ctypes.CDLL(None, use_errno=True)
except OSError as error:
    ATOMIC_ARCHIVE_RENAME_LIBRARY = None
    ATOMIC_ARCHIVE_RENAME = None
    ATOMIC_ARCHIVE_RENAME_DIAGNOSTIC = "cannot load the process C library: {}".format(
        error
    )
else:
    ATOMIC_ARCHIVE_RENAME, ATOMIC_ARCHIVE_RENAME_DIAGNOSTIC = (
        bind_atomic_archive_rename(sys.platform, ATOMIC_ARCHIVE_RENAME_LIBRARY)
    )


def archive_atomic_rename_boundary(_source, _destination):
    """Test probe immediately before the atomic no-replace operation."""


def atomic_archive_rename_no_replace(source, destination):
    """Atomically move one archive artifact without replacing any destination."""
    try:
        source_bytes = os.fsencode(source)
        destination_bytes = os.fsencode(destination)
    except TypeError as error:
        raise TypeError("archive move paths must be path-like values") from error
    for label, path, encoded in (
            ("source", source, source_bytes),
            ("destination", destination, destination_bytes)):
        if not encoded:
            raise ValueError("archive move {} path must not be empty".format(label))
        if b"\0" in encoded:
            raise ValueError(
                "archive move {} path must not contain a null byte".format(label)
            )
    if ATOMIC_ARCHIVE_RENAME is None:
        raise RuntimeError(
            "atomic no-replace archive move is unavailable ({}); refusing to "
            "move {} to {}".format(
                ATOMIC_ARCHIVE_RENAME_DIAGNOSTIC, source, destination,
            )
        )

    archive_atomic_rename_boundary(source, destination)
    ctypes.set_errno(0)
    result = ATOMIC_ARCHIVE_RENAME(source_bytes, destination_bytes)
    if result == 0:
        return
    error_number = ctypes.get_errno()
    if result != -1 or not error_number:
        raise RuntimeError(
            "atomic no-replace archive move returned an invalid native result "
            "for {} to {} using {}".format(
                source, destination, ATOMIC_ARCHIVE_RENAME_DIAGNOSTIC,
            )
        )
    if error_number == errno.EEXIST:
        raise ValueError(
            "refusing to overwrite archive transaction destination: {}"
            .format(destination)
        )
    unavailable_errors = {
        errno.EINVAL, errno.ENOSYS,
        getattr(errno, "ENOTSUP", errno.EINVAL),
        getattr(errno, "EOPNOTSUPP", errno.EINVAL),
    }
    if error_number in unavailable_errors:
        raise RuntimeError(
            "atomic no-replace archive move is unavailable on this filesystem "
            "using {}; refusing to move {} to {}: {}".format(
                ATOMIC_ARCHIVE_RENAME_DIAGNOSTIC, source, destination,
                os.strerror(error_number),
            )
        )
    raise OSError(
        error_number,
        "atomic no-replace archive move failed from {} to {} using {}: {}".format(
            source, destination, ATOMIC_ARCHIVE_RENAME_DIAGNOSTIC,
            os.strerror(error_number),
        ),
        source,
        None,
        destination,
    )


def durable_archive_rename(source, destination):
    if os.path.lexists(destination):
        raise ValueError(
            "refusing to overwrite archive transaction destination: {}"
            .format(destination)
        )
    atomic_archive_rename_no_replace(source, destination)
    for directory in dict.fromkeys((os.path.dirname(source), os.path.dirname(destination))):
        sync_directory(directory)


def archive_transaction_boundary(_name):
    """Test probe after each durable journal or artifact boundary."""


def complete_archive_transaction(baton_dir, transaction):
    states = [
        archive_artifact_state(baton_dir, artifact)
        for artifact in transaction["artifacts"]
    ]
    for index, (artifact, state) in enumerate(zip(transaction["artifacts"], states)):
        source, destination, source_exists = state
        if source_exists:
            durable_archive_rename(source, destination)
            archive_transaction_boundary("move-{}".format(index))


def remove_archive_transaction(baton_dir):
    journal = archive_transaction_path(baton_dir)
    os.unlink(journal)
    sync_directory(baton_dir)
    archive_transaction_boundary("journal-removed")


def rollback_archive_transaction(baton_dir, transaction):
    for artifact in reversed(transaction["artifacts"]):
        source, destination, source_exists = archive_artifact_state(baton_dir, artifact)
        if not source_exists:
            durable_archive_rename(destination, source)
    remove_archive_transaction(baton_dir)


def recover_archive_transaction(baton_dir):
    if not os.path.lexists(archive_transaction_path(baton_dir)):
        return False
    transaction = read_archive_transaction(baton_dir)
    validate_archive_transaction_topology(baton_dir, transaction)
    complete_archive_transaction(baton_dir, transaction)
    remove_archive_transaction(baton_dir)
    return True


def cmd_validate(args):
    baton_dir = require_baton_dir()
    problems = []
    root = project_root(baton_dir)
    if not is_git_repo(root):
        problems.append("repository: not a Git worktree")
    else:
        try:
            top_level = git_checked(root, "rev-parse", "--show-toplevel").strip()
            if os.path.realpath(root) != os.path.realpath(top_level):
                problems.append("repository: Baton is not at the worktree root")
            submodules = git_submodule_paths(root)
            if submodules:
                problems.append(
                    "repository: tracked submodules are unsupported: "
                    + ", ".join(submodules)
                )
        except RuntimeError as error:
            problems.append("repository: " + str(error))
    config = None
    memory_entries = ()
    try:
        config = load_config(baton_dir)
    except SystemExit as error:
        problems.append("config: {}".format(error))
    if config is not None:
        for validator in (
                configured_limits, configured_capsule_max_chars,
                configured_finish_requires_brief, configured_report_requires_sections,
                configured_accept_requires_brief, configured_phase_sequence_requires_briefs):
            try:
                validator(config)
            except ValueError as error:
                problems.append("config: {}".format(error))
        tiers = config.get("tiers", {})
        if not isinstance(tiers, dict):
            problems.append("config: tiers must be a table")
        else:
            for name in sorted(tiers):
                if not name.strip():
                    problems.append("config: tier name must be non-blank")
                    continue
                if name == "default":
                    problems.append("config: tier name 'default' is reserved")
                    continue
                section = tiers[name]
                prefix = "config: tier {!r}: ".format(name)
                before = len(problems)
                if not isinstance(section, dict):
                    problems.append(prefix + "[tiers.{}] must be a table".format(name))
                    continue
                for key, validator in (
                        ("command", validate_worker_template),
                        ("worker_timeout_minutes", configured_worker_timeout_minutes),
                        ("capsule_max_chars", validated_capsule_max_chars),
                        ("display", validated_display_metadata)):
                    if key not in section:
                        continue
                    try:
                        validator(section[key])
                    except ValueError as error:
                        problems.append(prefix + str(error))
                if len(problems) == before:
                    try:
                        tier = configured_tier(config, name)
                        validate_worker_executable(tier["command"], root)
                    except ValueError as error:
                        problems.append(prefix + str(error))
    try:
        _, memory_text = read_memory(baton_dir)
        memory_entries, _memory_bodies = memory_records(memory_text)
    except (OSError, UnicodeDecodeError, ValueError) as error:
        problems.append("memory: {}".format(error))
    try:
        active = load_all_tasks(baton_dir, validate_history=False)
        archived = load_archived_tasks(baton_dir, validate_history=False)
    except (OSError, UnicodeDecodeError, ValueError, json.JSONDecodeError) as error:
        say("PROBLEM: cannot read task state: {}".format(error))
        raise SystemExit(1) from error
    problems.extend(archive_layout_problems(baton_dir, active, archived))
    all_tasks = active + archived
    shapes = [task_validation_shape(task) for task in all_tasks]
    active_pairs = list(zip(active, shapes[:len(active)]))
    archived_pairs = list(zip(archived, shapes[len(active):]))
    known = {
        task["id"]: task for task, shape in zip(all_tasks, shapes) if shape["id"]
    }
    known_shapes = {
        task["id"]: shape for task, shape in zip(all_tasks, shapes) if shape["id"]
    }
    task_tier_cache = {}
    seen_ids = set()
    seen_numbers: dict[int, str] = {}
    for task, shape in zip(all_tasks, shapes):
        if not shape["id"]:
            continue
        task_id = task["id"]
        if task_id in seen_ids:
            problems.append("duplicate task id: {}".format(task_id))
        seen_ids.add(task_id)
        number = int(task_id[1:task_id.index("-")])
        previous_id = seen_numbers.get(number)
        if previous_id and previous_id != task_id:
            problems.append(
                "task number {} is reused by {} and {}".format(
                    number, previous_id, task_id,
                )
            )
        seen_numbers[number] = task_id
    for task, shape in active_pairs:
        problems.extend(task_problems(
            baton_dir, task, shape, known, known_shapes, memory_entries,
            config=config, tier_cache=task_tier_cache,
        ))
        if shape["id"]:
            task_id = task["id"]
            if not os.path.exists(task_md_path(baton_dir, task_id)):
                problems.append("{}: task spec is missing".format(task_id))
    for task, shape in archived_pairs:
        problems.extend(task_problems(
            baton_dir, task, shape, known, known_shapes, memory_entries,
            config=config, tier_cache=task_tier_cache, archived=True,
        ))
    running = [
        task for task, shape in active_pairs
        if shape["id"] and shape["status"] and shape["scope"]
        and task["status"] == "running"
    ]
    for index, first in enumerate(running):
        for second in running[index + 1:]:
            if scopes_overlap(first["scope"], second["scope"]):
                problems.append("running tasks {} and {} have overlapping scopes".format(
                    first["id"], second["id"],
                ))
    cycle_tasks = [
        task for task, shape in active_pairs if shape["id"] and shape["depends_on"]
    ]
    for cycle in dependency_cycles(cycle_tasks):
        problems.append("dependency cycle: " + " -> ".join(cycle))
    if problems:
        for problem in problems:
            say("PROBLEM: " + problem)
        raise SystemExit(1)
    say("ok: %d active task(s)" % len(active))


def cmd_archive(args):
    require_orchestrator()
    baton_dir = require_baton_dir()
    destination = archive_dir(baton_dir)
    os.makedirs(destination, exist_ok=True)
    with file_lock(lock_path(baton_dir, "scheduler")):
        blocked_signals = {signal.SIGINT, signal.SIGTERM}
        if hasattr(signal, "SIGHUP"):
            blocked_signals.add(signal.SIGHUP)
        previous_mask = signal.pthread_sigmask(signal.SIG_BLOCK, blocked_signals)
        try:
            recover_archive_transaction(baton_dir)
            eligible = [
                task for task in load_all_tasks(baton_dir)
                if task["status"] in ("done", "cancelled")
            ]
            if eligible:
                transaction = build_archive_transaction(baton_dir, eligible)
                atomic_json(archive_transaction_path(baton_dir), transaction)
                try:
                    archive_transaction_boundary("journal-created")
                    complete_archive_transaction(baton_dir, transaction)
                except BaseException as error:
                    try:
                        rollback_archive_transaction(baton_dir, transaction)
                    except BaseException as rollback_error:
                        raise RuntimeError(
                            "archive failed and durable rollback could not complete; "
                            "pending journal preserved at {}: {}"
                            .format(archive_transaction_path(baton_dir), rollback_error)
                        ) from error
                    raise
                remove_archive_transaction(baton_dir)
        finally:
            signal.pthread_sigmask(signal.SIG_SETMASK, previous_mask)
    say("archived %d task(s)" % len(eligible))


# Memory

def memory_path(baton_dir):
    return os.path.join(baton_dir, "memory.md")


def read_memory(baton_dir):
    path = memory_path(baton_dir)
    if not os.path.exists(path):
        die("missing memory.md")
    with open(path, encoding="utf-8") as source:
        return path, source.read()


def memory_index_entries(text):
    """Parse the strict memory index as ordered (id, audience, summary) tuples."""
    marker = re.search(r"^## Index[ \t]*$", text, re.MULTILINE)
    if not marker:
        raise ValueError("memory index is missing; expected a '## Index' section")
    following = re.search(r"^## [^\n]+[ \t]*$", text[marker.end():], re.MULTILINE)
    end = marker.end() + following.start() if following else len(text)
    entries = []
    seen = set()
    marker_line = text.count("\n", 0, marker.end()) + 1
    pattern = re.compile(r"- (M\d{3,}) \[([WOB])\] (\S(?:.*\S)?)")
    for offset, line in enumerate(text[marker.end():end].splitlines()):
        if not line:
            continue
        line_number = marker_line + offset
        match = pattern.fullmatch(line)
        if not match:
            raise ValueError(
                "memory index line {} is malformed; expected '- M### [W|O|B] "
                "summary': {!r}".format(line_number, line)
            )
        memory_id, audience, summary = match.groups()
        if memory_id in seen:
            raise ValueError(
                "memory index has duplicate id {} at line {}".format(
                    memory_id, line_number,
                )
            )
        seen.add(memory_id)
        entries.append((memory_id, audience, summary))
    return entries


def memory_entries_heading(text):
    """Return the structural Entries heading that immediately follows the index."""
    index_heading = re.search(r"^## Index[ \t]*$", text, re.MULTILINE)
    if not index_heading:
        return None
    following = re.search(
        r"^## [^\n]+[ \t]*$", text[index_heading.end():], re.MULTILINE,
    )
    if not following or not re.fullmatch(
            r"## Entries[ \t]*", following.group(0)):
        return None
    start = index_heading.end() + following.start()
    end = index_heading.end() + following.end()
    return (start, end)


def memory_records(text):
    """Validate index/body parity and return ordered index entries and rendered bodies."""
    index_headings = list(re.finditer(r"^## Index[ \t]*$", text, re.MULTILINE))
    entries_headings = list(re.finditer(r"^## Entries[ \t]*$", text, re.MULTILINE))
    if len(index_headings) != 1:
        raise ValueError(
            "malformed memory structure: expected exactly one '## Index' section"
        )
    if len(entries_headings) > 1:
        raise ValueError(
            "malformed memory structure: duplicate '## Entries' sections"
        )

    index_heading = index_headings[0]
    following = re.search(
        r"^## [^\n]+[ \t]*$", text[index_heading.end():], re.MULTILINE,
    )
    entries_heading = entries_headings[0] if entries_headings else None
    if entries_heading is not None and (
            entries_heading.start() < index_heading.end()
            or following is None
            or index_heading.end() + following.start() != entries_heading.start()):
        raise ValueError(
            "malformed memory structure: '## Entries' must be the first level-2 "
            "section after '## Index'"
        )
    if entries_heading is None and following is not None:
        raise ValueError(
            "malformed memory structure: noncanonical section between '## Index' "
            "and '## Entries'"
        )

    entry_heading_pattern = re.compile(
        r"^### (M\d{3,})(?:[ \t]+[^\n]*)?[ \t]*$", re.MULTILINE,
    )
    entry_like_headings = list(re.finditer(r"^### M[^\n]*$", text, re.MULTILINE))
    malformed_entry_lines = [
        text.count("\n", 0, heading.start()) + 1
        for heading in entry_like_headings
        if entry_heading_pattern.fullmatch(heading.group(0)) is None
    ]
    if malformed_entry_lines:
        raise ValueError(
            "malformed memory structure: invalid full entry headings at lines "
            + ", ".join(str(line) for line in malformed_entry_lines)
        )
    all_body_headings = list(entry_heading_pattern.finditer(text))
    orphaned_before_entries = [
        heading.group(1) for heading in all_body_headings
        if entries_heading is None or heading.start() < entries_heading.end()
    ]
    if orphaned_before_entries:
        raise ValueError(
            "malformed memory structure: orphan full entry headings outside "
            "'## Entries': " + ", ".join(orphaned_before_entries)
        )

    try:
        entries = memory_index_entries(text)
    except ValueError as error:
        raise ValueError("malformed memory structure: " + str(error)) from None
    index_by_id = {entry[0]: entry for entry in entries}
    if not entries_heading:
        if entries:
            raise ValueError(
                "malformed memory structure: memory full entries are missing for "
                "indexed ids: "
                + ", ".join(entry[0] for entry in entries)
            )
        return entries, {}

    heading_end = entries_heading.end()
    section = text[heading_end:]
    headings = list(re.finditer(
        r"^### (M\d{3,})(?:[ \t]+[^\n]*)?[ \t]*$", section, re.MULTILINE,
    ))
    parsed = {}
    ordered_body_ids = []
    mismatched = set()
    duplicates = set()
    heading_pattern = re.compile(
        r"### (M\d{3,}) \[([WOB])\] (\S(?:.*\S)?)[ \t]*"
    )
    for position, heading in enumerate(headings):
        memory_id = heading.group(1)
        if memory_id in parsed:
            duplicates.add(memory_id)
        else:
            ordered_body_ids.append(memory_id)
        body_end = (
            headings[position + 1].start()
            if position + 1 < len(headings) else len(section)
        )
        metadata = heading_pattern.fullmatch(heading.group(0))
        indexed = index_by_id.get(memory_id)
        if metadata is None or indexed is None or metadata.groups() != indexed:
            if indexed is not None:
                mismatched.add(memory_id)
        parsed.setdefault(memory_id, section[heading.start():body_end].strip())

    missing = [memory_id for memory_id, _audience, _summary in entries
               if memory_id not in parsed]
    orphaned = [
        memory_id for memory_id in ordered_body_ids if memory_id not in index_by_id
    ]
    problems = []
    if missing:
        problems.append("missing full entries for indexed ids: " + ", ".join(missing))
    if mismatched:
        problems.append("mismatched full entry headings for ids: " + ", ".join(
            memory_id for memory_id, _audience, _summary in entries
            if memory_id in mismatched
        ))
    if duplicates:
        problems.append("duplicate full entry headings for ids: " + ", ".join(
            memory_id for memory_id in ordered_body_ids if memory_id in duplicates
        ))
    if orphaned:
        problems.append("orphan full entry headings for ids: " + ", ".join(orphaned))
    if problems:
        raise ValueError(
            "malformed memory structure: memory index/body mismatch: "
            + "; ".join(problems)
        )
    return entries, parsed


def cmd_memory_index(args):
    baton_dir = require_baton_dir()
    _, text = read_memory(baton_dir)
    audience = {"worker": "W", "orchestrator": "O"}.get(args.audience)
    entries, _memory_bodies = memory_records(text)
    for entry in entries:
        if audience is None or entry[1] in (audience, "B"):
            say("{} [{}] {}".format(*entry))


def cmd_memory_show(args):
    baton_dir = require_baton_dir()
    _, text = read_memory(baton_dir)
    entries, bodies = memory_records(text)
    indexed = next(
        (entry for entry in entries if entry[0] == args.id),
        None,
    )
    if indexed is None:
        die("no memory entry {}".format(args.id))
    say(bodies[args.id])


def cmd_memory_add(args):
    require_orchestrator()
    baton_dir = require_baton_dir()
    if (
            not args.summary.strip()
            or args.summary != args.summary.strip()
            or not is_single_line_text(args.summary)
            or any(ord(character) < 32 or 127 <= ord(character) <= 159
                   for character in args.summary)):
        die("memory summary must be nonblank single-line text without control characters")
    if re.search(r"^### M", args.body, re.MULTILINE):
        die("memory body must not contain an entry heading beginning with `### M`")
    with file_lock(lock_path(baton_dir, "memory")):
        path, text = read_memory(baton_dir)
        entries, _memory_bodies = memory_records(text)
        tag = {"worker": "W", "orchestrator": "O", "both": "B"}[args.audience]
        numbers = [int(memory_id[1:]) for memory_id, _audience, _summary in entries] or [0]
        memory_id = "M%03d" % (max(numbers) + 1)
        index_line = "- {} [{}] {}".format(memory_id, tag, args.summary)
        entry = "### {} [{}] {}\n{}\n".format(memory_id, tag, args.summary, args.body)
        entries_heading = memory_entries_heading(text)
        if entries_heading:
            heading_start, heading_end = entries_heading
            head = text[:heading_start]
            marker_and_tail = text[heading_start:]
            text = head.rstrip() + "\n" + index_line + "\n\n" + marker_and_tail
            if marker_and_tail[heading_end - heading_start:].strip():
                text = text.rstrip() + "\n\n"
            else:
                text += "\n\n"
            text += entry
        else:
            text = text.rstrip() + "\n" + index_line + "\n\n## Entries\n\n" + entry
        memory_records(text)
        atomic_write(path, text)
    say("added {}".format(memory_id))


# Init and CLI

def cmd_init(args):
    require_orchestrator()
    target = os.path.abspath(args.path or ".")
    if not os.path.isdir(target):
        die("no such directory: {}".format(target))
    require_git_root(target)
    source = script_dir()
    baton_dir = os.path.join(target, BATON_DIRNAME)
    runtime_paths_are_safe(baton_dir)
    static_files = ("baton", "orchestrator.md", "worker.md")
    missing = [name for name in static_files if not os.path.exists(os.path.join(source, name))]
    memory_source = os.path.join(source, "memory.md")
    config_source = os.path.join(source, "config.example.toml")
    if not os.path.exists(config_source):
        config_source = os.path.join(source, "config.toml")
    if not os.path.exists(memory_source):
        missing.append("memory.md")
    if not os.path.exists(config_source):
        missing.append("config.example.toml or config.toml")
    if missing:
        die("framework files missing beside baton: {}".format(", ".join(missing)))
    os.makedirs(baton_dir, exist_ok=True)
    for name in static_files:
        destination = os.path.join(baton_dir, name)
        if os.path.exists(destination) and not args.force:
            continue
        if os.path.abspath(os.path.join(source, name)) != os.path.abspath(destination):
            shutil.copy2(os.path.join(source, name), destination)
    os.chmod(os.path.join(baton_dir, "baton"), 0o700)
    destination_memory = os.path.join(baton_dir, "memory.md")
    if not os.path.exists(destination_memory):
        shutil.copy2(memory_source, destination_memory)
    destination_config = os.path.join(baton_dir, "config.toml")
    if not os.path.exists(destination_config):
        shutil.copy2(config_source, destination_config)
    for subdirectory in ("tasks", "work", "archive", ".locks"):
        os.makedirs(os.path.join(baton_dir, subdirectory), exist_ok=True)
    gitignore = os.path.join(target, ".gitignore")
    existing = ""
    if os.path.exists(gitignore):
        with open(gitignore, encoding="utf-8") as source_file:
            existing = source_file.read()
    if BATON_DIRNAME + "/" not in existing.splitlines():
        updated = existing
        if updated and not updated.endswith("\n"):
            updated += "\n"
        updated += BATON_DIRNAME + "/\n"
        atomic_write(gitignore, updated)
        say("added .baton/ to .gitignore")
    say("initialized {}".format(baton_dir))
    say("next: have your coding agent read .baton/orchestrator.md")


def build_parser():
    parser = argparse.ArgumentParser(prog="baton", description=__doc__)
    commands = parser.add_subparsers(dest="command", required=True)

    command = commands.add_parser("init", help="install Baton in a Git project")
    command.add_argument("path", nargs="?", help="project directory (default: .)")
    command.add_argument("--force", action="store_true", help="refresh baton and its manuals")
    command.set_defaults(function=cmd_init)

    task = commands.add_parser("task", help="manage tasks")
    task_commands = task.add_subparsers(dest="task_command", required=True)

    command = task_commands.add_parser("create", help="create a task")
    command.add_argument("--title", required=True)
    command.add_argument("--scope", action="append")
    command.add_argument("--depends-on", action="append", dest="depends_on")
    command.add_argument("--tier", required=True, help="explicit task difficulty/tier")
    command.set_defaults(function=cmd_task_create)

    command = task_commands.add_parser("list", help="list active tasks")
    command.add_argument("--json", action="store_true")
    command.set_defaults(function=cmd_task_list)

    command = task_commands.add_parser("show", help="show task state")
    command.add_argument("id")
    command.set_defaults(function=cmd_task_show)

    command = task_commands.add_parser("capsule", help="preview a task capsule and its budget")
    command.add_argument("id")
    command.add_argument("--raw", action="store_true", help="print only the capsule bytes")
    command.set_defaults(function=cmd_task_capsule)

    command = task_commands.add_parser("accept", help="approve reviewed work")
    command.add_argument("id")
    command.add_argument("--note")
    command.add_argument("--brief")
    command.set_defaults(function=cmd_task_accept)

    command = task_commands.add_parser("return", help="queue another attempt")
    command.add_argument("id")
    command.add_argument("--reason", required=True)
    command.set_defaults(function=cmd_task_return)

    command = task_commands.add_parser("decide", help="answer a worker question")
    command.add_argument("id")
    command.add_argument("--answer", required=True)
    command.set_defaults(function=cmd_task_decide)

    command = task_commands.add_parser("cancel", help="cancel a task")
    command.add_argument("id")
    command.add_argument("--reason")
    command.set_defaults(function=cmd_task_cancel)

    command = task_commands.add_parser("finish", help="submit a worker result")
    command.add_argument("id")
    command.add_argument("--status", required=True, choices=WORKER_FINAL)
    command.add_argument("--note")
    command.add_argument("--changed", action="append", default=[])
    command.add_argument("--brief")
    command.set_defaults(function=cmd_task_finish)

    command = task_commands.add_parser("brief", help="reprint the worker capsule and phase checklist")
    command.add_argument("id")
    command.add_argument("--phase", required=True, choices=("edit", "verify", "report"))
    command.set_defaults(function=cmd_task_brief)

    command = task_commands.add_parser("unlock", help="clear a stale runner")
    command.add_argument("id")
    command.set_defaults(function=cmd_task_unlock)

    command = commands.add_parser("run", help="run one non-conflicting task wave")
    command.add_argument("ids", nargs="*")
    command.add_argument("--max-parallel", type=int)
    command.add_argument("--dry-run", action="store_true")
    command.set_defaults(function=cmd_run)

    command = commands.add_parser("status", help="show tasks needing attention")
    command.set_defaults(function=cmd_status)

    command = commands.add_parser("stats", help="show read-only task statistics")
    command.add_argument(
        "--task", dest="task_ids", action="append", default=[], metavar="ID",
        help="report worker use for one request task (repeatable)",
    )
    command.set_defaults(function=cmd_stats)

    command = commands.add_parser("tiers", help="show effective worker tier settings")
    command.set_defaults(function=cmd_tiers)

    command = commands.add_parser("validate", help="check config and task state")
    command.set_defaults(function=cmd_validate)

    command = commands.add_parser("archive", help="archive done and cancelled tasks")
    command.set_defaults(function=cmd_archive)

    orchestrator = commands.add_parser("orchestrator", help="orchestrator phase briefs")
    orchestrator_commands = orchestrator.add_subparsers(
        dest="orchestrator_command", required=True,
    )
    command = orchestrator_commands.add_parser(
        "brief", help="print a state-derived orchestrator phase brief",
    )
    command.add_argument(
        "--phase", required=True, choices=("start", "plan", "run", "review", "close"),
    )
    command.add_argument("id", nargs="?")
    command.add_argument(
        "--include-log-tail", action="store_true",
        help="append a bounded sanitized log tail (review phase only)",
    )
    command.add_argument(
        "--goal", metavar="TEXT",
        help="set the next-session goal (required for the close phase)",
    )
    command.add_argument(
        "--avoid", metavar="TEXT", action="append", default=[],
        help="add a next-session avoid note (close phase only, repeatable)",
    )
    command.add_argument(
        "--note", metavar="TEXT", action="append", default=[],
        help="add trusted next-session context (close phase only, repeatable)",
    )
    command.set_defaults(function=cmd_orchestrator_brief)

    hooks = commands.add_parser("hooks", help="configure optional host integrations")
    hook_commands = hooks.add_subparsers(dest="hooks_command", required=True)
    command = hook_commands.add_parser(
        "claude-code", help="print or install Claude Code hook settings",
    )
    command.add_argument("--write", action="store_true")
    command.set_defaults(function=cmd_hooks_claude_code)

    command = commands.add_parser("hook-event", help=argparse.SUPPRESS)
    command.add_argument("name", choices=("session-start", "user-prompt-submit"))
    command.set_defaults(function=cmd_hook_event)

    memory = commands.add_parser("memory", help="manage indexed project memory")
    memory_commands = memory.add_subparsers(dest="memory_command", required=True)

    command = memory_commands.add_parser("index", help="list memory entries")
    command.add_argument("--for", dest="audience", choices=("worker", "orchestrator"))
    command.set_defaults(function=cmd_memory_index)

    command = memory_commands.add_parser("show", help="show one memory entry")
    command.add_argument("id")
    command.set_defaults(function=cmd_memory_show)

    command = memory_commands.add_parser("add", help="add a durable project fact")
    command.add_argument("--for", dest="audience", required=True,
                         choices=("worker", "orchestrator", "both"))
    command.add_argument("summary")
    command.add_argument("body")
    command.set_defaults(function=cmd_memory_add)
    return parser


def main(argv=None):
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        args.function(args)
    except (OSError, UnicodeDecodeError, RuntimeError, ValueError, json.JSONDecodeError) as error:
        die(str(error))


if __name__ == "__main__":
    main()
