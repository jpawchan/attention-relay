def unknown_tier_error(config, name):
    known = configured_tier_names(config)
    return "unknown tier {!r}; known tiers: {}".format(
        name, ", ".join(known) or "(none)",
    )


def validate_worker_template(template):
    if not isinstance(template, str) or not template.strip():
        raise ValueError("no worker command configured")
    try:
        argv = shlex.split(template)
    except ValueError as error:
        raise ValueError("invalid worker command: {}".format(error)) from error
    placeholders = [(index, token) for index, token in enumerate(argv)
                    if token in ("{prompt}", "{prompt_file}")]
    if len(placeholders) != 1:
        raise ValueError("worker command needs exactly one {prompt} or {prompt_file} argument")
    for token in argv:
        if ("{prompt}" in token or "{prompt_file}" in token) and token not in (
                "{prompt}", "{prompt_file}"):
            raise ValueError("the prompt placeholder must be a complete command argument")
    return argv


def configured_tier(config, name):
    if not isinstance(name, str) or not name.strip():
        raise ValueError("tier name must be non-blank")
    tiers = config.get("tiers", {})
    if not isinstance(tiers, dict):
        raise ValueError("tiers must be a table")
    if name not in tiers or name == "default":
        raise ValueError(unknown_tier_error(config, name))
    section = tiers[name]
    if not isinstance(section, dict):
        raise ValueError("[tiers.{}] must be a table".format(name))

    command_source = "tier" if "command" in section else "global"
    template = section.get("command", cfg_get(config, "commands.worker", ""))
    validate_worker_template(template)
    timeout = configured_worker_timeout_minutes(section.get(
        "worker_timeout_minutes",
        cfg_get(config, "limits.worker_timeout_minutes", 60),
    ))
    capsule_max_chars = validated_capsule_max_chars(section.get(
        "capsule_max_chars", cfg_get(config, "limits.capsule_max_chars", 4000),
    ))
    display = validated_display_metadata(section.get("display"))
    return {
        "name": name,
        "command": template,
        "command_source": command_source,
        "worker_timeout_minutes": timeout,
        "capsule_max_chars": capsule_max_chars,
        "display": display,
    }


def configured_task_tier(config, task, cache=None):
    """Resolve a task tier, optionally reusing validation within one command."""
    name = task.get("tier")
    if cache is None or not isinstance(name, str) or not name.strip():
        return configured_tier(config, name)
    if name not in cache:
        try:
            cache[name] = (configured_tier(config, name), None)
        except ValueError as error:
            cache[name] = (None, str(error))
    tier, problem = cache[name]
    if problem is not None:
        raise ValueError(problem)
    return tier


def command_template(config, task):
    return configured_tier(config, task.get("tier"))["command"]


def resolved_task_label(config, task, tier_cache=None):
    tier = configured_task_tier(config, task, tier_cache)
    title = flatten_bounded_text(task.get("title"), 120)
    return "{} | title={} | difficulty={} | worker={}".format(
        task["id"], title or "(untitled)", tier["name"], worker_display_label(tier),
    )


def displayed_task(config, task, tier_cache=None):
    """Return task state enriched only with safe, effective routing metadata."""
    tier = configured_task_tier(config, task, tier_cache)
    displayed = dict(task)
    displayed["difficulty"] = tier["name"]
    displayed["worker_label"] = worker_display_label(tier)
    displayed["routing"] = "difficulty={} | worker={}".format(
        tier["name"], displayed["worker_label"],
    )
    return displayed


def worker_argv(config, task, prompt, prompt_file, root):
    argv = validate_worker_executable(command_template(config, task), root)
    index, placeholder = next(
        (index, token) for index, token in enumerate(argv)
        if token in ("{prompt}", "{prompt_file}")
    )
    argv[index] = prompt if placeholder == "{prompt}" else prompt_file
    return argv


