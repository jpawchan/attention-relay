def latest_worker_exit(task):
    for entry in reversed(task.get("history", [])):
        if entry.get("event") == "worker_exited":
            return entry
    return {}


def compile_current_task_capsule(baton_dir, task):
    config = load_config(baton_dir)
    _, memory_text = read_memory(baton_dir)
    memory_entries, _memory_bodies = memory_records(memory_text)
    with open(task_md_path(baton_dir, task["id"]), encoding="utf-8") as source:
        return compile_context_capsule(
            task, source.read(), memory_entries,
            configured_tier(config, task.get("tier"))["capsule_max_chars"],
        )


def displayed_review_capsule(baton_dir, task, check_fresh=False):
    """Select the capsule review displays, optionally checking current-input drift."""
    attempt = task.get("attempt", 1)
    brief_file = os.path.join(
        work_dir(baton_dir, task["id"]), "attempt-%d.brief.md" % attempt,
    )
    if os.path.lexists(brief_file):
        if os.path.islink(brief_file) or not os.path.isfile(brief_file):
            raise OSError("current attempt capsule is missing or invalid; rerun the task")
        with open(brief_file, encoding="utf-8") as source:
            stored_brief = source.read()
        _digest, separator, stored_capsule = stored_brief.partition("\n\n")
        if not separator or not stored_capsule.startswith("# Critical Context Capsule"):
            raise ValueError("current attempt capsule is missing or invalid; rerun the task")
        if not check_fresh:
            return stored_capsule, False, None
        try:
            fresh_capsule = compile_current_task_capsule(baton_dir, task)
        except (OSError, UnicodeDecodeError, ValueError, json.JSONDecodeError) as error:
            error_text = " ".join(str(error).split())[:400]
            warning = (
                "capsule inputs could not be compiled since launch; showing launch "
                "capsule: " + error_text
            )
            return stored_capsule, False, warning
        return stored_capsule, fresh_capsule != stored_capsule, None
    return compile_current_task_capsule(baton_dir, task), False, None


def orchestrator_review_brief(baton_dir, task_id, include_log_tail=False):
    import secrets

    with task_lock(baton_dir, task_id):
        task = load_task(baton_dir, task_id)
        if task.get("status") != "needs_review":
            die("{} is {}, not needs_review".format(task["id"], task.get("status")))
        attempt = task.get("attempt", 1)
        capsule, capsule_drifted, compile_warning = displayed_review_capsule(
            baton_dir, task, check_fresh=True,
        )
        report_problems = report_gate_problems(
            report_path(baton_dir, task["id"], attempt), "needs_review",
            configured_report_requires_sections(load_config(baton_dir)),
        )
        if report_problems:
            die("report rejected: " + "; ".join(report_problems))
        manifest = build_review_evidence_manifest(baton_dir, task, capsule)
        worker_exit = latest_worker_exit(task)
        diff_summary = attempt_diff_summary(
            diff_path(baton_dir, task["id"], attempt),
            manifest["evidence"]["observed"],
        )
        prior_artifacts = []
        omitted_prior_attempts = 0
        for prior_attempt in range(attempt - 1, 0, -1):
            paths = []
            for name, artifact in (
                    ("report", report_path(baton_dir, task["id"], prior_attempt)),
                    ("diff", diff_path(baton_dir, task["id"], prior_attempt))):
                if os.path.isfile(artifact) and not os.path.islink(artifact):
                    paths.append((name, artifact))
            if paths:
                if len(prior_artifacts) < 3:
                    prior_artifacts.append((prior_attempt, paths))
                else:
                    omitted_prior_attempts += 1
        log = os.path.join(work_dir(baton_dir, task["id"]), "attempt-%d.log" % attempt)
        log_tail = untrusted_log_tail_block(log) if include_log_tail else None
        receipts = read_phase_receipts(
            phase_receipts_path(baton_dir, task["id"], attempt),
            task["id"], attempt,
        )
        token = secrets.token_hex(32)
        token_record = dict(manifest)
        token_record["token"] = token
        atomic_json(review_token_path(baton_dir, task["id"]), token_record)
    root = project_root(baton_dir)
    report = report_path(baton_dir, task["id"], attempt)
    result_file = result_path(baton_dir, task["id"], attempt)
    diff = diff_path(baton_dir, task["id"], attempt)
    evidence = manifest["evidence"]
    say(capsule)
    if compile_warning:
        say("\nWARNING: " + compile_warning)
    elif capsule_drifted:
        say(
            "\nWARNING: capsule inputs drifted since launch (spec or memory changed); "
            "showing launch capsule"
        )
    if task.get("warning"):
        say("\nWARNING: Worker exited with code {} after submission; inspect log: {}".format(
            worker_exit.get("exit_code"), os.path.relpath(log, root),
        ))
    say("\nReview artifacts:")
    say("- Report: {} (sha256:{})".format(
        os.path.relpath(report, root), evidence["report"][7:19],
    ))
    say("- Result: {} (sha256:{})".format(
        os.path.relpath(result_file, root), evidence["result"][7:19],
    ))
    say("- Diff: {} (sha256:{})".format(
        os.path.relpath(diff, root), evidence["diff"][7:19],
    ))
    declared = evidence["declared"]
    observed = evidence["observed"]
    say("- Declared changed paths: " + (
        ", ".join(declared) if declared else "(none)"
    ))
    say("- Observed changed paths: " + (
        ", ".join(observed) if observed else "(none recorded)"
    ))
    if receipts is None:
        say("Phase briefs: none recorded")
    else:
        say("Phase briefs: " + " ".join(
            "{}={}".format(phase, receipts["phases"].get(phase, {}).get("count", 0))
            for phase in ("edit", "verify", "report")
        ))
    if not diff_summary["files"]:
        say("Diff stat: no changes")
    else:
        say("Diff stat: {} files, +{} -{}".format(
            len(diff_summary["files"]),
            diff_summary["added"], diff_summary["removed"],
        ))
        stat_lines = [
            "{}: +{} -{} {}".format(
                item["path"], item["added"], item["removed"], item["label"],
            )
            for item in diff_summary["files"]
        ]
        for line in limited_lines(stat_lines, limit=10):
            say("- " + line)
    if prior_artifacts:
        say("Prior attempt artifacts (most recent first):")
        for prior_attempt, paths in prior_artifacts:
            for name, artifact in paths:
                say("- attempt {} {}: {}".format(
                    prior_attempt, name, os.path.relpath(artifact, root),
                ))
        if omitted_prior_attempts:
            say("- +{} older attempt{}".format(
                omitted_prior_attempts,
                "s" if omitted_prior_attempts != 1 else "",
            ))
    if log_tail is not None:
        say("\n" + log_tail)
    say("Review checklist:")
    say("- Compare the report, diff, and declared/observed paths to the criteria.")
    say("- Verify the reported checks and inspect risky full files when needed.")
    say("- Accept with this token, return with a concrete reason, or decide a question.")
    say("Review token: " + token)


def orchestrator_run_brief(baton_dir, tasks):
    config = load_config(baton_dir)
    max_parallel, _timeout = configured_limits(config)
    archived = load_archived_tasks(baton_dir)
    busy_scopes = [task.get("scope", []) for task in tasks
                   if task.get("status") == "running"]
    wave, skipped = pick_wave(tasks, archived, [], max_parallel, busy_scopes)
    try:
        labels = [resolved_task_label(config, task) for task in wave]
    except ValueError as error:
        die(str(error))
    say("Would run: " + (", ".join(labels) or "(nothing)"))
    cautions = [(task_id, reason) for task_id, reason in skipped
                if "scope conflicts" in reason or "waiting on" in reason]
    say("Cautions:")
    for task_id, reason in cautions[:10]:
        say("- {}: {}".format(task_id, reason))
    if len(cautions) > 10:
        say("- +{} more".format(len(cautions) - 10))
    if not cautions:
        say("- none")


def working_tree_state(root):
    """Return True for dirty, False for clean, and None when Git is unavailable."""
    env = dict(os.environ, GIT_OPTIONAL_LOCKS="0")
    try:
        with tempfile.TemporaryFile() as output:
            result = subprocess.run(
                [
                    "git", "-C", root, "status", "--porcelain=v1",
                    "--untracked-files=normal", "--ignore-submodules=none",
                ],
                env=env, stdout=output, stderr=subprocess.DEVNULL,
                timeout=5,
            )
            if result.returncode:
                return None
            return output.tell() > 0
    except (OSError, subprocess.TimeoutExpired):
        return None


def worker_usage_sentence(tasks, for_request=False):
    """Summarize recorded worker launches for a request or the whole runtime."""
    counts = {name: 0 for name in CONVENTIONAL_LEVELS}
    other = 0
    for task in tasks:
        if not isinstance(task, dict):
            continue
        history = task.get("history", [])
        if not isinstance(history, list):
            continue
        launches = sum(
            1 for entry in history
            if isinstance(entry, dict) and entry.get("event") == "launched"
        )
        tier = task.get("tier")
        if isinstance(tier, str) and tier in counts:
            counts[tier] += launches
        else:
            other += launches

    total = sum(counts.values()) + other
    if for_request:
        phrases = ["{} on {}".format(counts[level], level)
                   for level in CONVENTIONAL_LEVELS]
        if other:
            phrases.append("{} on other levels".format(other))
        breakdown = ", ".join(phrases[:-1]) + ", and " + phrases[-1]
        return "I used {} worker{} for this request: {}.".format(
            total, "s" if total != 1 else "", breakdown,
        )

    def level_phrase(count, level):
        if count == 1:
            article = "an" if level[0] in "aeiou" else "a"
            return "1 for {} {} task".format(article, level)
        return "{} for {} tasks".format(count, level)

    phrases = [level_phrase(counts[level], level) for level in CONVENTIONAL_LEVELS]
    if other:
        phrases.append("{} for other level{}".format(other, "s" if other != 1 else ""))
    breakdown = ", ".join(phrases[:-1]) + ", and " + phrases[-1]
    return "I used {} worker{} for this Baton runtime so far: {}.".format(
        total, "s" if total != 1 else "", breakdown,
    )


def orchestrator_close_brief(
        baton_dir, tasks, archived_tasks, goal, avoid_notes, notes, working_tree):
    done_candidates = []
    decisions = []
    for task in tasks + archived_tasks:
        history = task.get("history", [])
        if not isinstance(history, list):
            history = []
        for entry in history:
            if not isinstance(entry, dict):
                continue
            if entry.get("event") == "accepted":
                done_candidates.append((
                    entry.get("at", ""), task["id"], task.get("title", ""),
                    flatten_bounded_text(entry.get("note", ""), 120),
                ))
            if entry.get("event") == "decided":
                decisions.append((entry.get("at", ""), "{}: {}".format(
                    task["id"], entry.get("answer", ""),
                )))
    decisions = [text for _at, text in sorted(decisions, reverse=True)]
    accepted_ids = {
        task_id for _accepted_at, task_id, _title, _outcome in done_candidates
    }
    next_ids = [task["id"] for task in tasks
                if task.get("status") in {"queued", "needs_review"}]
    unresolved = [task["id"] for task in tasks
                  if task.get("status") == "needs_decision"]
    with file_lock(lock_path(baton_dir, "orchestrator-handoff")):
        previous = read_handoff(baton_dir)
        previous_at = handoff_field(previous, "generated_at")
        previous_seen = handoff_done_ids(previous)
        cursor = read_handoff_cursor(baton_dir)
        reported_ids = set()
        carried_done = []
        carried_done_omitted = 0
        if cursor is not None and cursor["version"] == 3:
            if not cursor["reported_ids"].issubset(accepted_ids):
                die("orchestrator handoff cursor is invalid")
            reported_ids.update(cursor["reported_ids"])
            if not handoff_presentations_match(cursor["handoff"], previous):
                carried_done, carried_done_omitted = handoff_done_presentation(
                    cursor["handoff"],
                )
        else:
            if cursor is not None and cursor["version"] == 2:
                previous_at = cursor["accepted_at"]
                previous_seen = (
                    set(cursor["seen_ids"])
                    | handoff_done_ids(cursor["handoff"])
                )
                if not handoff_presentations_match(cursor["handoff"], previous):
                    carried_done, carried_done_omitted = handoff_done_presentation(
                        cursor["handoff"],
                    )
            elif cursor is not None and cursor["accepted_at"] == previous_at:
                previous_seen.update(cursor["seen_ids"])
            elif cursor is not None:
                # A version-1 cursor and Markdown were separate publications.
                # Recover from their last visible boundary and migrate atomically.
                pass
            # Legacy cursors only identify their current timestamp boundary.
            # Preserve that format's deterministic behavior once during migration:
            # earlier acceptances are treated as reported and unseen acceptances at
            # or after the boundary remain eligible. Only snapshot-backed accepted
            # IDs are trusted when the durable version-3 identity set is created.
            reported_ids.update(previous_seen & accepted_ids)
            if previous_at:
                reported_ids.update(
                    task_id for accepted_at, task_id, _title, _outcome
                    in done_candidates if accepted_at < previous_at
                )
        done = {}
        for _accepted_at, task_id, title, outcome in done_candidates:
            if task_id not in reported_ids:
                done[task_id] = (task_id, title, outcome)
        generated_at = now()
        reported_ids.update(done)
        content = render_handoff(
            generated_at, goal, working_tree, sorted(done.values()), decisions,
            next_ids, unresolved, notes, avoid_notes, carried_done,
            carried_done_omitted,
        )
        atomic_json(orchestrator_handoff_cursor_path(baton_dir), {
            "version": 3,
            "reported_ids": sorted(reported_ids),
            "handoff": content,
        })
        atomic_write(orchestrator_handoff_path(baton_dir), content)
    say(content.rstrip())
    say(worker_usage_sentence(tasks + archived_tasks))
    say(
        "Start a fresh coding-agent session and tell it to read "
        ".baton/orchestrator.md."
    )


def cmd_orchestrator_brief(args):
    require_orchestrator()
    baton_dir = require_baton_dir()
    tasks = None
    if args.phase != "close":
        tasks = load_all_tasks(baton_dir)
    if args.include_log_tail and args.phase != "review":
        die("--include-log-tail is valid only for the review phase")
    if args.goal is not None and args.phase != "close":
        die("`--goal` is valid only for the close phase")
    if args.avoid and args.phase != "close":
        die("`--avoid` is valid only for the close phase")
    if args.note and args.phase != "close":
        die("`--note` is valid only for the close phase")
    if args.phase == "review" and not args.id:
        die("review phase requires a task id")
    if args.id and args.phase != "review":
        die("a task id is valid only for the review phase")
    if args.phase == "close":
        if len(args.avoid) > 5:
            die("at most 5 `--avoid` notes are allowed; consolidate them")
        if len(args.note) > 3:
            die("at most 3 `--note` values are allowed; consolidate them")
        goal = flatten_bounded_text(args.goal, 200)
        if not goal:
            die("`--phase close` requires a nonblank goal; add `--goal TEXT`")
        avoid_notes = [
            note for note in (
                flatten_bounded_text(value, 200) for value in args.avoid
            ) if note
        ]
        notes = []
        for note in (flatten_bounded_text(value, 160) for value in args.note):
            if note and note not in notes:
                notes.append(note)
    if args.phase == "review":
        orchestrator_review_brief(baton_dir, args.id, args.include_log_tail)
    elif args.phase == "start":
        orchestrator_start_brief(baton_dir, tasks)
    elif args.phase == "plan":
        orchestrator_plan_brief(tasks)
    elif args.phase == "run":
        orchestrator_run_brief(baton_dir, tasks)
    else:
        tree_state = working_tree_state(project_root(baton_dir))
        with file_lock(lock_path(baton_dir, "scheduler")):
            tasks = load_all_tasks(baton_dir, validate_history=False)
            archived_tasks = load_archived_tasks(baton_dir, validate_history=False)
            orchestrator_close_brief(
                baton_dir, tasks, archived_tasks, goal, avoid_notes, notes, tree_state,
            )


def claude_code_hook_fragment():
    return {
        "hooks": {
            event: [{"hooks": [{"type": "command", "command": command}]}]
            for event, command in CLAUDE_HOOK_COMMANDS.items()
        },
    }


def claude_hook_command_is_registered(entries, command):
    for entry in entries:
        if not isinstance(entry, dict):
            continue
        hooks = entry.get("hooks")
        if not isinstance(hooks, list):
            continue
        if any(isinstance(hook, dict) and hook.get("command") == command for hook in hooks):
            return True
    return False


