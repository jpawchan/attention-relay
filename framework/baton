def read_handoff_cursor(baton_dir):
    """Read strict legacy or identity-based canonical handoff state."""
    path = orchestrator_handoff_cursor_path(baton_dir)
    if not os.path.exists(path):
        return None
    if os.path.islink(path) or not os.path.isfile(path):
        die("orchestrator handoff cursor must be a regular file")
    try:
        with open(path, encoding="utf-8") as source:
            cursor = json.load(source)
    except (OSError, UnicodeDecodeError, json.JSONDecodeError) as error:
        die("cannot parse orchestrator handoff cursor: {}".format(error))
    if not isinstance(cursor, dict):
        die("orchestrator handoff cursor must contain a JSON object")
    version = cursor.get("version")
    if type(version) is not int:
        die("orchestrator handoff cursor is invalid")
    if version in (1, 2):
        required = {"version", "accepted_at", "seen_ids"}
        if version == 2:
            required.add("handoff")
        accepted_at = cursor.get("accepted_at")
        seen_ids = cursor.get("seen_ids")
        if (
                set(cursor) != required
                or not is_utc_timestamp(accepted_at)
                or not isinstance(seen_ids, list)
                or not all(isinstance(task_id, str) and TASK_ID_RE.fullmatch(task_id)
                           for task_id in seen_ids)
                or len(seen_ids) != len(set(seen_ids))):
            die("orchestrator handoff cursor is invalid")
        state = {
            "version": version, "accepted_at": accepted_at,
            "seen_ids": set(seen_ids),
        }
    elif version == 3:
        reported_ids = cursor.get("reported_ids")
        if (
                set(cursor) != {"version", "reported_ids", "handoff"}
                or not isinstance(reported_ids, list)
                or not all(isinstance(task_id, str) and TASK_ID_RE.fullmatch(task_id)
                           for task_id in reported_ids)
                or len(reported_ids) != len(set(reported_ids))):
            die("orchestrator handoff cursor is invalid")
        state = {"version": version, "reported_ids": set(reported_ids)}
    else:
        die("orchestrator handoff cursor is invalid")
    if version in (2, 3):
        handoff = cursor.get("handoff")
        if (
                not isinstance(handoff, str)
                or handoff_structure(handoff) is None
                or (version == 2
                    and handoff_field(handoff, "generated_at") != accepted_at)):
            die("orchestrator handoff cursor is invalid")
        state["handoff"] = handoff
    return state


def handoff_field(content, name, default=""):
    match = re.search(r"^{}:[ \t]*(.*)$".format(re.escape(name)), content, re.MULTILINE)
    return match.group(1).strip() if match else default


HANDOFF_SECTION_NAMES = ("done", "decisions", "next", "unresolved", "notes", "avoid")


def handoff_structure(content):
    """Return section membership for one readable, budgeted handoff."""
    if (
            not isinstance(content, str)
            or not content.endswith("\n")
            or len(content) > HANDOFF_MAX_CHARS):
        return None
    lines = content.splitlines()
    if (
            len(lines) < 6
            or lines[0] != "# Orchestrator handoff"
            or not re.fullmatch(r"generated_at: (.+)", lines[1])
            or not is_utc_timestamp(lines[1][len("generated_at: "):])
            or not re.fullmatch(r"consumed_at: (.+)", lines[2])
            or not (
                lines[2][len("consumed_at: "):] == HANDOFF_CONSUMED_AT_PLACEHOLDER
                or is_utc_timestamp(lines[2][len("consumed_at: "):])
            )
            or not re.fullmatch(r"goal: \S.*", lines[3])):
        return None

    section_indices = []
    section_by_line = {}
    current_section = None
    previous_order = -1
    for index, line in enumerate(lines[4:], 4):
        if line.endswith(":") and line[:-1] in HANDOFF_SECTION_NAMES:
            order = HANDOFF_SECTION_NAMES.index(line[:-1])
            if order <= previous_order:
                return None
            previous_order = order
            current_section = line[:-1]
            section_indices.append((index, current_section))
        elif current_section is None:
            if index != 4 or not re.fullmatch(r"warning: \S.*", line):
                return None
        elif not line.startswith("- "):
            return None
        else:
            section_by_line[index] = current_section
    if not section_indices or section_indices[0][1] != "done":
        return None
    for position, (index, _name) in enumerate(section_indices):
        end = (
            section_indices[position + 1][0]
            if position + 1 < len(section_indices) else len(lines)
        )
        if end == index + 1:
            return None
    return section_by_line


def consume_handoff_content(content, consumed_at):
    """Validate and consume a handoff, compacting legacy prose before publish.

    Legacy handoffs could use all 4,000 characters before consumption. Their
    trailing presentation prose may be shortened deterministically, but metadata,
    headings, list syntax, and every task ID are retained byte-for-byte.
    """
    section_by_line = handoff_structure(content)
    if section_by_line is None or not is_utc_timestamp(consumed_at):
        raise ValueError("orchestrator handoff is invalid")
    lines = content.splitlines()
    lines[2] = "consumed_at: " + consumed_at
    consumed = "\n".join(lines) + "\n"
    overflow = len(consumed) - HANDOFF_MAX_CHARS
    if overflow <= 0:
        return consumed

    prose_candidates = []
    goal_candidates = []
    identity_candidates = []
    for index, line in enumerate(lines):
        minimum = None
        matches = list(TASK_ID_RE.finditer(line))
        if index == 3:
            minimum = len("goal: x")
        elif line.startswith("warning: "):
            minimum = len("warning: x")
        elif index in section_by_line:
            if line in ("- (none)", "- (fill in)") or re.fullmatch(
                    r"- \+[1-9]\d* more", line):
                continue
            if matches:
                minimum = max(match.end() for match in matches)
                if section_by_line[index] == "done" and line[minimum:minimum + 1] == ":":
                    minimum += 1
            else:
                minimum = len("- x")
        if minimum is not None and matches:
            minimum = max(minimum, max(match.end() for match in matches))
        if minimum is None or len(line) <= minimum:
            continue
        candidate = (index, minimum)
        if matches:
            identity_candidates.append(candidate)
        elif index == 3:
            goal_candidates.append(candidate)
        else:
            prose_candidates.append(candidate)

    for index, minimum in prose_candidates + goal_candidates + identity_candidates:
        removable = len(lines[index]) - minimum
        removed = min(overflow, removable)
        lines[index] = lines[index][:-removed]
        overflow -= removed
        if not overflow:
            break
    if overflow:
        raise ValueError("orchestrator handoff cannot be consumed within its budget")
    consumed = "\n".join(lines) + "\n"
    if handoff_structure(consumed) is None:
        raise ValueError("compacted orchestrator handoff is invalid")
    return consumed


def handoff_done_ids(content):
    match = re.search(r"^done:[ \t]*\n((?:^- .*(?:\n|$))*)", content, re.MULTILINE)
    if not match:
        return set()
    return {
        line[2:].split(":", 1)[0].strip()
        for line in match.group(1).splitlines()
        if line.startswith("- ") and ":" in line
    }


def handoff_done_presentation(content):
    """Return rendered done task lines and their separate omitted-task count."""
    match = re.search(r"^done:[ \t]*\n((?:^- .*(?:\n|$))*)", content, re.MULTILINE)
    if not match:
        return [], 0
    lines = [
        line[2:] for line in match.group(1).splitlines()
        if line.startswith("- ") and line[2:] != "(none)"
    ]
    omitted = 0
    if lines:
        summary = re.fullmatch(r"\+([1-9]\d*) more", lines[-1])
        if summary:
            omitted = int(summary.group(1))
            lines.pop()
    return lines, omitted


def handoff_presentations_match(canonical, presentation):
    """Treat start-phase consumption as presentation-equivalent publication."""
    def normalized(content):
        return re.sub(
            r"^consumed_at:.*$", "consumed_at: (normalized)", content,
            count=1, flags=re.MULTILINE,
        )

    return normalized(canonical) == normalized(presentation)


def limited_lines(values, limit=8, omitted=0):
    rendered = [str(value).replace("\n", " ")[:240] for value in values]
    if len(rendered) > limit:
        omitted += len(rendered) - limit
        rendered = rendered[:limit]
    if omitted:
        rendered.append("+{} more".format(omitted))
    return rendered or ["(none)"]


def handoff_task_line(task_id, title, outcome, include_outcome=True):
    """Render one done value while preserving its id prefix and 240-char bound."""
    prefix = task_id + ": "
    suffix = ""
    if include_outcome and outcome:
        suffix = " — outcome: " + outcome
    title_budget = max(0, 240 - len(prefix) - len(suffix))
    bounded_title = flatten_bounded_text(title, title_budget)
    return (prefix + bounded_title + suffix)[:240]


def render_handoff(
        generated_at, goal, working_tree, done, decisions, next_ids, unresolved,
        notes, avoid_notes, carried_done=(), carried_done_omitted=0):
    """Render a handoff with deterministic section-aware budget degradation."""
    warning = {
        True: "warning: uncommitted Git-visible changes at close",
        None: "warning: working-tree check unavailable at close",
    }.get(working_tree)
    limits = {name: 8 for name in ("done", "decisions", "next", "unresolved")}

    def build(include_outcomes):
        sections = [
            "# Orchestrator handoff", "generated_at: " + generated_at,
            "consumed_at: " + HANDOFF_CONSUMED_AT_PLACEHOLDER, "goal: " + goal,
        ]
        if warning:
            sections.append(warning)
        values_by_name = {
            "done": list(carried_done) + [
                handoff_task_line(task_id, title, outcome, include_outcomes)
                for task_id, title, outcome in done
            ],
            "decisions": decisions,
            "next": next_ids,
            "unresolved": unresolved,
        }
        for name in ("done", "decisions", "next", "unresolved"):
            sections.append(name + ":")
            sections.extend(
                "- " + line for line in limited_lines(
                    values_by_name[name], limit=limits[name],
                    omitted=carried_done_omitted if name == "done" else 0,
                )
            )
        if notes:
            sections.append("notes:")
            sections.extend("- " + note for note in notes)
        sections.append("avoid:")
        sections.extend(
            "- " + line for line in limited_lines(avoid_notes or ["(fill in)"])
        )
        return "\n".join(sections) + "\n"

    content = build(include_outcomes=True)
    if len(content) <= HANDOFF_UNCONSUMED_MAX_CHARS:
        if handoff_structure(content) is None:
            raise RuntimeError("rendered handoff is invalid")
        return content

    content = build(include_outcomes=False)
    for group in (("done", "decisions"), ("next", "unresolved")):
        while (
                len(content) > HANDOFF_UNCONSUMED_MAX_CHARS
                and any(limits[name] for name in group)):
            for name in group:
                if len(content) <= HANDOFF_UNCONSUMED_MAX_CHARS:
                    break
                if limits[name]:
                    limits[name] -= 1
                    content = build(include_outcomes=False)
    if len(content) > HANDOFF_UNCONSUMED_MAX_CHARS:
        raise RuntimeError(
            "bounded handoff fields exceed the consumption-reserved "
            "3989-character budget"
        )
    if handoff_structure(content) is None:
        raise RuntimeError("rendered handoff is invalid")
    return content


def orchestrator_start_brief(baton_dir, tasks, consume_handoff=True):
    say("Orchestrator role:")
    say("- Translate the user goal into small, observable tasks.")
    say("- Run only non-conflicting work and resolve worker decisions.")
    say("- Review reports and diffs before accepting any task.")
    routing_lines = worker_routing_lines(
        load_config(baton_dir), project_root(baton_dir),
    )
    say("\n" + routing_lines[0])
    for line in routing_lines[1:]:
        say(line)
    if consume_handoff:
        with file_lock(lock_path(baton_dir, "orchestrator-handoff")):
            presentation = read_handoff(baton_dir)
            cursor = read_handoff_cursor(baton_dir)
            handoff = (
                cursor["handoff"]
                if cursor is not None and cursor["version"] in (2, 3)
                else presentation
            )
            if handoff:
                consumed = now()
                try:
                    handoff = consume_handoff_content(handoff, consumed)
                except ValueError as error:
                    die(str(error))
                if cursor is not None and cursor["version"] in (2, 3):
                    cursor_content = {"version": cursor["version"], "handoff": handoff}
                    if cursor["version"] == 2:
                        cursor_content.update({
                            "accepted_at": cursor["accepted_at"],
                            "seen_ids": sorted(cursor["seen_ids"]),
                        })
                    else:
                        cursor_content["reported_ids"] = sorted(
                            cursor["reported_ids"]
                        )
                    atomic_json(
                        orchestrator_handoff_cursor_path(baton_dir), cursor_content,
                    )
                atomic_write(orchestrator_handoff_path(baton_dir), handoff)
    else:
        presentation = read_handoff(baton_dir)
        cursor = read_handoff_cursor(baton_dir)
        handoff = (
            cursor["handoff"]
            if cursor is not None and cursor["version"] in (2, 3)
            else presentation
        )
    if handoff:
        say("\nCurrent handoff:")
        say(handoff.rstrip())
    counts = {}
    for task in tasks:
        counts[task["status"]] = counts.get(task["status"], 0) + 1
    say("\nTask counts: " + (
        ", ".join("{}={}".format(*item) for item in sorted(counts.items())) or "none"
    ))
    decision_tasks = [task for task in tasks if task.get("status") == "needs_decision"]
    decisions = bounded_ids(tasks, {"needs_decision"})
    reviews = bounded_ids(tasks, {"needs_review"})
    say("Needs decision: " + (", ".join(decisions) or "none"))
    shown_questions = 0
    for task in decision_tasks:
        question = flatten_bounded_text(decision_question(task), 160)
        if question:
            say("- {}: worker question: {}".format(task["id"], question))
            shown_questions += 1
            if shown_questions == 2:
                break
    say("Needs review: " + (", ".join(reviews) or "none"))
    if decision_tasks:
        command = ".baton/baton task decide {} --answer ANSWER".format(decision_tasks[0]["id"])
    elif reviews:
        command = ".baton/baton orchestrator brief --phase review {}".format(reviews[0])
    elif any(task.get("status") == "queued" for task in tasks):
        command = ".baton/baton orchestrator brief --phase run"
    else:
        command = ".baton/baton orchestrator brief --phase plan"
    say("Recommended next command: " + command)


