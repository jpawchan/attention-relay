        memory_entries, _memory_bodies = memory_records(memory_text)
        with open(task_md_path(baton_dir, task["id"]), encoding="utf-8") as source:
            result = context_capsule_components(
                task, source.read(), memory_entries, maximum,
            )
        capsule = result["text"]
        source_label = "current spec (prospective)"

    digest = hashlib.sha256(capsule.encode("utf-8")).hexdigest()
    if args.raw:
        if result["overflow"]:
            print("error: " + capsule_budget_error(task["id"], result), file=sys.stderr)
            raise SystemExit(1)
        sys.stdout.buffer.write(capsule.encode("utf-8"))
        sys.stdout.buffer.flush()
        return

    say(capsule)
    say()
    say("Capsule diagnostics:")
    if result["overflow"]:
        budget_detail = "{} chars overflow".format(result["overflow"])
    else:
        budget_detail = "{} chars headroom".format(result["headroom"])
    say("Capsule: {} of {} chars ({})".format(
        result["chars"], result["maximum"], budget_detail,
    ))
    say("Sections:")
    for label, count in result["section_chars"]:
        say("- {}: {} chars".format(label, count))
    say("Digest: sha256:" + digest)
    say("Source: " + source_label)
    if result["overflow"]:
        print("error: " + capsule_budget_error(task["id"], result), file=sys.stderr)
        raise SystemExit(1)


def append_md_section(baton_dir, task_id, section, text):
    path = task_md_path(baton_dir, task_id)
    if not os.path.exists(path):
        return
    with open(path, encoding="utf-8", newline="") as source:
        content = source.read()
    marker = "## " + section
    heading = next(
        (item for item in task_spec_heading_lines(content) if item[0] == section), None,
    )
    if heading is not None:
        heading_end = heading[2]
        line_end = heading[3]
        if line_end == heading_end:
            content += "\n" + text
        else:
            content = content[:line_end] + text + content[line_end:]
    else:
        content = content.rstrip() + "\n\n" + marker + "\n" + text
    atomic_write(path, content)


def retry_publication_marker(task_id, transition, attempt, entry):
    """Return the collision-resistant proof line for one retry publication."""
    payload = json.dumps(
        ["baton-retry-publication-v1", task_id, transition, attempt, entry],
        ensure_ascii=False, separators=(",", ":"),
    ).encode("utf-8")
    digest = hashlib.sha256(payload).hexdigest()
    return (
        "<!-- baton-retry-publication:v1 transition={} attempt={} "
        "digest=sha256:{} -->"
    ).format(transition, attempt, digest)


def publish_retry_context(
        baton_dir, task_id, transition, attempt, section, text):
    """Publish one retry entry with an adjacent, section-bound proof."""
    path = task_md_path(baton_dir, task_id)
    entry = text
    marker = retry_publication_marker(task_id, transition, attempt, entry)

    def published():
        if not os.path.exists(path):
            raise OSError(
                "cannot publish retry context; task specification is missing: " + path
            )
        with open(path, encoding="utf-8", newline="") as source:
            return task_spec_has_retry_publication(
                source.read(), section, marker, entry,
            )

    if published():
        return
    legacy_entry_offset = None
    if is_single_line_text(entry):
        with open(path, encoding="utf-8", newline="") as source:
            content = source.read()
        legacy_entry_offset = task_spec_unfenced_entry_offset(
            content, section, entry,
        )
    if legacy_entry_offset is not None:
        atomic_write(
            path,
            content[:legacy_entry_offset] + marker + "\n"
            + content[legacy_entry_offset:],
        )
    else:
        append_md_section(
            baton_dir, task_id, section, marker + "\n" + entry + "\n",
        )
    if not published():
        raise OSError(
            "cannot publish retry context in task specification section " + section
        )


def ensure_not_live(task):
    runner = task.get("runner")
    if runner and pid_alive(runner.get("pid")):
        die("{} still has a live worker".format(task["id"]))


def cmd_task_accept(args):
    require_orchestrator()
    baton_dir = require_baton_dir()
    config = load_config(baton_dir)
    accept_requires_brief = configured_accept_requires_brief(config)
    report_requires_sections = configured_report_requires_sections(config)
    with file_lock(lock_path(baton_dir, "scheduler")):
        with task_lock(baton_dir, args.id):
            task = load_task(baton_dir, args.id)
            ensure_not_live(task)
            if task.get("scope_violations"):
                die("{} has unresolved scope violations".format(task["id"]))
            if task["status"] != "needs_review":
                die("{} is {}, not needs_review".format(task["id"], task["status"]))
            report_problems = report_gate_problems(
                report_path(baton_dir, task["id"], task.get("attempt", 1)),
                "needs_review", report_requires_sections,
            )
            if report_problems:
                die("report rejected: " + "; ".join(report_problems))
            token_path = review_token_path(baton_dir, task["id"])
            if accept_requires_brief:
                stored = None
                if os.path.isfile(token_path):
                    try:
                        stored = read_json(token_path)
                    except (OSError, UnicodeDecodeError, json.JSONDecodeError):
                        stored = None
                if (
                        not args.brief
                        or not isinstance(stored, dict)
                        or stored.get("task_id") != task["id"]
                        or stored.get("attempt") != task.get("attempt", 1)
                        or stored.get("token") != args.brief):
                    die(
                        "a fresh review-phase brief token is required; run `baton "
                        "orchestrator brief --phase review {}`, then pass its token as "
                        "`--brief TOKEN`".format(task["id"])
                    )
                try:
                    capsule, _capsule_drifted, _compile_warning = displayed_review_capsule(
                        baton_dir, task,
                    )
                    current_manifest = build_review_evidence_manifest(
                        baton_dir, task, capsule,
                    )
                except (OSError, UnicodeDecodeError, ValueError, json.JSONDecodeError) as error:
                    die(
                        "review evidence changed; run a fresh review brief: {}"
                        .format(error)
                    )
                stored_manifest = dict(stored)
                stored_manifest.pop("token", None)
                if current_manifest != stored_manifest:
                    die("review evidence changed; run a fresh review brief")
            else:
                try:
                    review_evidence_details(baton_dir, task)
                except (
                        OSError, UnicodeDecodeError, ValueError,
                        json.JSONDecodeError) as error:
                    die("review evidence is inconsistent: {}".format(error))
            task["status"] = "done"
            record(task, "accepted", note=args.note or "")
            save_task(baton_dir, task)
            if accept_requires_brief:
                os.unlink(token_path)
    say("{} accepted".format(task["id"]))


def cmd_task_return(args):
