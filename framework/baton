            or int(task_id[1:task_id.index("-")]) < 1):
        raise ValueError("task id must look like T001-short-slug")


def normalize_scope(pattern):
    import posixpath

    if not isinstance(pattern, str):
        raise ValueError("scope must be text")
    pattern = pattern.strip()
    if not pattern:
        raise ValueError("scope cannot be empty")
    if pattern == ".":
        return None
    if "\\" in pattern:
        raise ValueError("scope must use forward slashes")
    if pattern.startswith("/") or re.match(r"^[A-Za-z]:", pattern):
        raise ValueError("scope must be relative to the project")
    if any(part == ".." for part in pattern.split("/")):
        raise ValueError("scope cannot contain ..")
    if "[" in pattern or "]" in pattern:
        raise ValueError("scope supports *, **, and ? but not character classes")
    normalized = posixpath.normpath(pattern)
    while normalized.startswith("./"):
        normalized = normalized[2:]
    if normalized == ".":
        return None
    for part in normalized.split("/"):
        if "**" in part and part != "**":
            raise ValueError("** must be a complete path segment")
    return normalized


def normalize_scopes(scopes):
    if not scopes:
        return []
    normalized = []
    keys = set()
    for scope in scopes:
        value = normalize_scope(scope)
        if value is None:
            return []
        key = value.casefold()
        if key not in keys:
            normalized.append(value)
            keys.add(key)
    return normalized


def fixed_scope_prefix(scope):
    prefix = []
    for part in scope.split("/"):
        if "*" in part or "?" in part:
            break
        prefix.append(part.casefold())
    return tuple(prefix)


def scopes_overlap(first, second):
    if not first or not second:
        return True
    for left in first:
        for right in second:
            a = fixed_scope_prefix(left)
            b = fixed_scope_prefix(right)
            shared = min(len(a), len(b))
            if a[:shared] == b[:shared]:
                return True
    return False


class ScopeOverlapIndex:
    """Index leased literal prefixes using the same rule as scopes_overlap."""

    def __init__(self, scopes=()):
        self.root = [0, False, {}]
        self.lease_count = 0
        for scope in scopes:
            self.add(scope)

    def add(self, scopes):
        self.lease_count += 1
        prefixes = [fixed_scope_prefix(scope) for scope in scopes] if scopes else [()]
        for prefix in prefixes:
            node = self.root
            node[0] += 1
            for part in prefix:
                node = node[2].setdefault(part, [0, False, {}])
                node[0] += 1
            node[1] = True

    def overlaps(self, scopes):
        if not self.lease_count:
            return False
        if not scopes:
            return True
        for scope in scopes:
            node = self.root
            if node[1]:
                return True
            for part in fixed_scope_prefix(scope):
                node = node[2].get(part)
                if node is None:
                    break
                if node[1]:
                    return True
            else:
                if node[0]:
                    return True
        return False


def scope_pattern_matches(path, pattern):
    import fnmatch

    path_parts = tuple(part.casefold() for part in path.split("/") if part)
    pattern_parts = tuple(part.casefold() for part in pattern.split("/") if part)
    memo: dict[tuple[int, int], bool] = {}

    def match(path_index, pattern_index):
        key = (path_index, pattern_index)
        if key in memo:
            return memo[key]
        if pattern_index == len(pattern_parts):
            answer = path_index == len(path_parts)
        elif pattern_parts[pattern_index] == "**":
            answer = match(path_index, pattern_index + 1) or (
                path_index < len(path_parts) and match(path_index + 1, pattern_index)
            )
        else:
            answer = (
                path_index < len(path_parts)
                and fnmatch.fnmatchcase(path_parts[path_index], pattern_parts[pattern_index])
                and match(path_index + 1, pattern_index + 1)
            )
        memo[key] = answer
        return answer

    return match(0, 0)


def normalize_changed_path(path):
    """Validate one literal canonical project-relative path without glob parsing."""
    if not isinstance(path, str):
        raise ValueError("changed paths must be text")
    if not path:
        raise ValueError("changed paths cannot be empty")
    if "\0" in path:
        raise ValueError("changed paths cannot contain NUL")
    if path.startswith("/") or re.match(r"^[A-Za-z]:", path):
        raise ValueError("changed paths must be relative to the project")
    if any(part in ("", ".", "..") for part in path.split("/")):
        raise ValueError("changed paths must be canonical project-relative paths")
    return path


def normalize_changed_paths(paths):
    normalized = []
    keys = set()
    for path in paths:
        value = normalize_changed_path(path)
        key = value.casefold()
        if key not in keys:
            normalized.append(value)
            keys.add(key)
    return normalized


def path_in_scopes(path, scopes):
    if not scopes:
        return True
    path = path.replace(os.sep, "/")
    if path.startswith("./"):
        path = path[2:]
    path_key = path.casefold()
    for scope in scopes:
        scope_key = scope.casefold()
        if "*" not in scope and "?" not in scope:
            if path_key == scope_key or path_key.startswith(scope_key + "/"):
                return True
        elif scope_pattern_matches(path, scope):
            return True
    return False


def next_task_id(baton_dir, title, tasks=None):
    numbers = [0]
    if tasks is None:
        tasks = load_all_tasks(baton_dir) + load_archived_tasks(baton_dir)
    for task in tasks:
        match = re.match(r"T(\d+)", task.get("id", ""))
        if match:
            numbers.append(int(match.group(1)))
    return "T%03d-%s" % (max(numbers) + 1, slugify(title))


TASK_MD_TEMPLATE = """# {id}: {title}

## Objective
Replace this line with one clear outcome.

## Acceptance criteria
- Add observable requirements.

## Context
List the paths and facts the worker needs. Reference memory ids when useful.

## Not allowed
- No changes outside the task scope.
- No unrelated cleanup or new dependencies.

## Verification
- Add exact, targeted commands.

## Decisions

## Review feedback
"""


CAPSULE_SECTIONS = (
    "Objective", "Acceptance criteria", "Not allowed", "Verification",
)
CAPSULE_MEMORY_MAX_REFERENCES = 6
CAPSULE_REQUIRED_PLACEHOLDERS = {
    "Objective": "Replace this line with one clear outcome.",
    "Acceptance criteria": "- Add observable requirements.",
}


def task_spec_unfenced_lines(spec):
    """Yield source lines outside fences, with None separating fenced blocks."""
    fence_state = None
    offset = 0
    for line in spec.splitlines(keepends=True):
        if line.endswith("\r\n"):
            body = line[:-2]
        elif line.endswith(("\r", "\n")):
            body = line[:-1]
        else:
            body = line
        previous_fence_state = fence_state
        fence_state = commonmark_fence_state(body, fence_state)
        if previous_fence_state is not None or fence_state is not None:
            yield None
        else:
            yield offset, body, line
        offset += len(line)


def task_spec_heading_lines(spec):
    """Return level-2 headings and their source line ends outside fences."""
    headings = []
    for scanned in task_spec_unfenced_lines(spec):
        if scanned is None:
            continue
        offset, body, line = scanned
        heading = re.fullmatch(r"## (.+?)[ \t]*", body)
        if heading:
            headings.append((
                heading.group(1).strip(), offset, offset + len(body),
                offset + len(line),
            ))
    return headings


def task_spec_headings(spec):
    """Return level-2 task headings outside CommonMark fenced code blocks."""
    return [heading[:3] for heading in task_spec_heading_lines(spec)]


def task_spec_contains_unfenced_entry(spec, entry):
    """Return whether an exact entry occurs outside fenced code blocks."""
    for scanned in task_spec_unfenced_lines(spec):
        if scanned is not None and scanned[1] == entry:
            return True
    return False


def task_spec_section_bounds(spec, section):
    """Return the body bounds for the first exact, unfenced task section."""
    headings = task_spec_heading_lines(spec)
    for index, (name, _heading_start, _heading_end, line_end) in enumerate(headings):
        if name != section:
            continue
        body_start = line_end
        body_end = headings[index + 1][1] if index + 1 < len(headings) else len(spec)
        return body_start, body_end
    return None


def task_spec_unfenced_entry_offset(spec, section, entry):
    """Return the offset of an exact single-line entry in one task section."""
    in_section = False
    for scanned in task_spec_unfenced_lines(spec):
        if scanned is None:
            continue
        offset, body, _line = scanned
        heading = re.fullmatch(r"## (.+?)[ \t]*", body)
        if heading:
            if in_section:
                return None
            in_section = heading.group(1).strip() == section
            continue
        if in_section and body == entry:
            return offset
    return None


def task_spec_has_retry_publication(spec, section, marker, entry):
    """Return whether one section contains an unfenced proof bound to its entry."""
    in_section = False
    for scanned in task_spec_unfenced_lines(spec):
        if scanned is None:
            continue
        offset, body, line = scanned
        heading = re.fullmatch(r"## (.+?)[ \t]*", body)
        if heading:
            if in_section:
                return False
            in_section = heading.group(1).strip() == section
            continue
        if not in_section or body != marker:
            continue
        entry_start = offset + len(line)
        entry_end = entry_start + len(entry)
        if spec[entry_start:entry_end] != entry:
            continue
        if entry.endswith(("\r", "\n")) or entry_end == len(spec):
            return True
        if spec.startswith(("\r\n", "\r", "\n"), entry_end):
            return True
    return False


def task_spec_sections(spec):
    """Return top-level task sections without reading files or changing state."""
    matches = task_spec_headings(spec)
    sections = {}
    for index, (name, _start, heading_end) in enumerate(matches):
        end = matches[index + 1][1] if index + 1 < len(matches) else len(spec)
        sections.setdefault(name, spec[heading_end:end].strip())
    return sections


def latest_task_spec_entry(text):
    """Return the newest list entry (Baton prepends feedback and decisions)."""
    for line in text.splitlines():
        entry = line.strip()
        if entry and not entry.startswith("<!-- baton-retry-publication:v1 "):
            return entry
    return ""


def render_context_capsule(parts):
    """Render ordered capsule parts using the canonical separators."""
    rendered = []
    for index, (label, text) in enumerate(parts):
        if index == 0:
            rendered.append(text)
        elif label == "Task":
            rendered.append("\n\n" + text)
        elif label == "Scope":
            rendered.append("\n" + text)
        else:
            rendered.append("\n\n" + text)
    return "".join(rendered)


def capsule_components_result(parts, capsule_max_chars):
    """Return rendered text and measurements for ordered capsule parts."""
    if isinstance(capsule_max_chars, bool) or not isinstance(capsule_max_chars, int) \
            or capsule_max_chars < 1:
        raise ValueError("capsule_max_chars must be a positive integer")
    capsule = render_context_capsule(parts)
    size = len(capsule)
    return {
        "text": capsule,
        "parts": tuple(parts),
        "section_chars": tuple((label, len(text)) for label, text in parts),
        "chars": size,
        "maximum": capsule_max_chars,
        "overflow": max(0, size - capsule_max_chars),
        "headroom": max(0, capsule_max_chars - size),
    }


def context_capsule_components(task, spec, memory_entries, capsule_max_chars=4000):
    """Build a deterministic capsule and measurements without enforcing its budget."""
    if isinstance(capsule_max_chars, bool) or not isinstance(capsule_max_chars, int) \
            or capsule_max_chars < 1:
        raise ValueError("capsule_max_chars must be a positive integer")
    sections = task_spec_sections(spec)
    task_id = task.get("id", "unknown")
    for name in ("Objective", "Acceptance criteria"):
        content = sections.get(name, "")
        if not content:
            raise ValueError(
                "{}: {} is empty; replace the template text with task-specific content".format(
                    task_id, name,
                )
            )
        placeholder = CAPSULE_REQUIRED_PLACEHOLDERS[name]
        if placeholder in (line.strip() for line in content.splitlines()):
            raise ValueError(
                "{}: {} still contains the template placeholder {!r}; replace it with "
                "task-specific content".format(task_id, name, placeholder)
            )

    references = list(dict.fromkeys(
        re.findall(r"\bM\d{3,}\b", sections.get("Context", ""))
    ))
    if len(references) > CAPSULE_MEMORY_MAX_REFERENCES:
        raise ValueError(
            "{}: Context references {} memory entries; maximum is {}; split the task "
            "or remove references".format(
                task_id, len(references), CAPSULE_MEMORY_MAX_REFERENCES,
            )
        )
    memory_by_id = {
        memory_id: (audience, summary)
        for memory_id, audience, summary in memory_entries
    }
    referenced_memory = []
    for memory_id in references:
        entry = memory_by_id.get(memory_id)
        if entry is None:
            raise ValueError(
                "{}: referenced memory id {} is missing from memory.md".format(
                    task_id, memory_id,
                )
            )
        audience, summary = entry
        if audience == "O":
            raise ValueError(
                "{}: referenced memory id {} is orchestrator-only [O]; worker capsules "
                "may reference only [W] or [B]".format(task_id, memory_id)
            )
        referenced_memory.append((memory_id, summary))

    scope = ", ".join(task.get("scope", [])) or "whole project"
    parts = [
        ("Header", "# Critical Context Capsule"),
        ("Task", "Task: {}: {}".format(task_id, task.get("title", ""))),
        ("Scope", "Scope: " + scope),
    ]
    for name in CAPSULE_SECTIONS:
        parts.append((name, "## {}\n{}".format(
            name, sections.get(name, "") or "(none)",
        )))
    if referenced_memory:
        lines = [
            "Load full entries as needed with "
            "`python3 .baton/baton memory show ID`.",
        ]
        lines.extend("- {}: {}".format(*entry) for entry in referenced_memory)
        parts.append((
            "Referenced memory", "## Referenced memory\n" + "\n".join(lines),
        ))
    if task.get("attempt", 1) > 1:
        feedback = latest_task_spec_entry(sections.get("Review feedback", ""))
        decision = latest_task_spec_entry(sections.get("Decisions", ""))
        retry = []
        if feedback:
            retry.append("Review feedback: " + feedback)
        if decision:
            retry.append("Decision: " + decision)
        parts.append(("Retry delta", "## Retry delta\n" + (
            "\n".join(retry) or "(none recorded)"
        )))
    return capsule_components_result(parts, capsule_max_chars)


def stored_context_capsule_components(capsule, capsule_max_chars=4000):
    """Measure a stored launch capsule without consulting mutable task spec text."""
    labels = (*CAPSULE_SECTIONS, "Referenced memory", "Retry delta")
    matches = list(re.finditer(
        r"(?:^|\n\n)## ({})\n".format("|".join(map(re.escape, labels))), capsule,
    ))
    found = [match.group(1) for match in matches]
    valid_sections = [
        list(CAPSULE_SECTIONS),
        [*CAPSULE_SECTIONS, "Referenced memory"],
        [*CAPSULE_SECTIONS, "Retry delta"],
        [*CAPSULE_SECTIONS, "Referenced memory", "Retry delta"],
    ]
    if found not in valid_sections:
        raise ValueError("stored capsule sections are missing or invalid")
    prefix = capsule[:matches[0].start()]
    header, separator, task_scope = prefix.partition("\n\n")
    task_scope_lines = task_scope.splitlines()
    if (header != "# Critical Context Capsule" or not separator
            or len(task_scope_lines) < 2
            or not task_scope_lines[0].startswith("Task: ")
            or not task_scope_lines[-1].startswith("Scope: ")):
        raise ValueError("stored capsule header is missing or invalid")
    parts = [
        ("Header", header),
        ("Task", "\n".join(task_scope_lines[:-1])),
        ("Scope", task_scope_lines[-1]),
    ]
    for index, match in enumerate(matches):
        start = match.start() + (2 if capsule.startswith("\n\n", match.start()) else 0)
        end = matches[index + 1].start() if index + 1 < len(matches) else len(capsule)
        parts.append((match.group(1), capsule[start:end]))
    result = capsule_components_result(parts, capsule_max_chars)
    if result["text"] != capsule:
        raise ValueError("stored capsule separators are invalid")
    return result


def capsule_budget_error(task_id, result):
    return (
        "{}: critical context capsule is {} characters; capsule_max_chars={} "
        "is exceeded by {} characters".format(
            task_id, result["chars"], result["maximum"], result["overflow"],
        )
    )


def compile_context_capsule(task, spec, memory_entries, capsule_max_chars=4000):
    """Compile a deterministic, bounded capsule from canonical task sections."""
    result = context_capsule_components(task, spec, memory_entries, capsule_max_chars)
    if result["overflow"]:
        raise ValueError(
            capsule_budget_error(task.get("id", "unknown"), result)
        )
    return result["text"]


def cmd_task_create(args):
    require_orchestrator()
    if not args.title.strip():
        die("task title cannot be empty")
    if (
            not is_single_line_text(args.title)
            or any(ord(character) < 32 or 127 <= ord(character) <= 159
                   for character in args.title)):
        die("task title must be single-line text without control characters")
    baton_dir = require_baton_dir()
    tier_name = args.tier
    try:
        config = load_config(baton_dir)
        configured_tier(config, tier_name)
    except ValueError as error:
        die(str(error))
    with file_lock(lock_path(baton_dir, "scheduler")):
        active_tasks = load_all_tasks(baton_dir)
        archived_tasks = load_archived_tasks(baton_dir)
        all_tasks = active_tasks + archived_tasks
        task_id = next_task_id(baton_dir, args.title, all_tasks)
        try:
            validate_task_id(task_id)
            scopes = normalize_scopes(args.scope)
        except ValueError as error:
            die(str(error))
        if any(task.get("id") == task_id for task in all_tasks):
            die("task already exists: {}".format(task_id))
        dependencies = args.depends_on or []
        if len(dependencies) != len(set(dependencies)):
            die("dependencies cannot be repeated")
        if task_id in dependencies:
            die("a task cannot depend on itself")
        known = {task["id"]: task for task in all_tasks}
        for dependency in dependencies:
            if dependency not in known:
                die("unknown dependency: {}".format(dependency))
            if known[dependency]["status"] == "cancelled":
                die("dependency is cancelled: {}".format(dependency))
        task = {
            "id": task_id,
            "title": args.title,
            "status": "queued",
            "attempt": 1,
            "tier": tier_name,
            "scope": scopes,
            "depends_on": dependencies,
            "created_at": now(),
            "updated_at": now(),
            "history": [],
        }
        record(task, "created")
        os.makedirs(tasks_dir(baton_dir), exist_ok=True)
        save_task(baton_dir, task)
        atomic_write(task_md_path(baton_dir, task_id), TASK_MD_TEMPLATE.format(
            id=task_id, title=args.title,
        ))
    say("created " + resolved_task_label(config, task))
    say("edit {}".format(os.path.relpath(task_md_path(baton_dir, task_id))))


