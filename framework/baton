REASON_CODE_RE = re.compile(r"^[a-z_]+(_\d+)?$")
POST_SUBMISSION_WARNING_RE = re.compile(r"^worker_exit_\d+_after_submission$")


def stats_count_lines(counts, limit=12, numeric=False):
    items = sorted(counts.items(), key=lambda item: item[0] if numeric else str(item[0]))
    if len(items) > limit:
        shown = items[:limit - 1]
        omitted = sum(count for _name, count in items[limit - 1:])
        existing_other = next((count for name, count in shown if name == "other"), 0)
        shown = [(name, count) for name, count in shown if name != "other"]
        shown.append(("other", existing_other + omitted))
        items = shown
    return ["- {}={}".format(name, count) for name, count in items] or ["- none"]


