def request_tasks_by_id(task_ids, active, archived):
    """Resolve a deduplicated request boundary before emitting any statistics."""
    by_id = {
        task.get("id"): task for task in active + archived
        if isinstance(task, dict) and isinstance(task.get("id"), str)
    }
    selected = []
    seen = set()
    for task_id in task_ids:
        try:
            validate_task_id(task_id)
        except ValueError as error:
            die(str(error))
        if task_id in seen:
            continue
        if task_id not in by_id:
            die("unknown task " + task_id)
        seen.add(task_id)
        selected.append(by_id[task_id])
    return selected


def cmd_stats(args):
    """Print bounded aggregate runtime evidence without write-capable locks."""
    require_orchestrator()
    baton_dir = require_baton_dir()
    active = load_all_tasks(baton_dir)
    archived = load_archived_tasks(baton_dir)
    if args.task_ids:
        say(worker_usage_sentence(
            request_tasks_by_id(args.task_ids, active, archived),
            for_request=True,
        ))
        return
    located_tasks = [(task, False) for task in active] + [
        (task, True) for task in archived
    ]
    if not located_tasks:
        say("no task data")
        return

    statuses = {}
    attempts = {}
    reasons = {}
    capsule_chars = []
    warning_count = 0
    attempt_keys = set()
    receipt_phases = {phase: set() for phase in ("edit", "verify", "report")}
    receipt_name = re.compile(r"^attempt-(\d+)\.briefs\.json$")

    for task, archived_task in located_tasks:
        status = task.get("status")
        status_code = status if status in STATUSES else "other"
        statuses[status_code] = statuses.get(status_code, 0) + 1
        attempt = task.get("attempt")
        if isinstance(attempt, int) and not isinstance(attempt, bool) and attempt > 0:
            attempts[attempt] = attempts.get(attempt, 0) + 1

        relevant_exits = []
        warning_entries = 0
        history = task.get("history", [])
        if not isinstance(history, list):
            history = []
        for entry in history:
            if not isinstance(entry, dict) or entry.get("event") not in {
                    "launched", "worker_exited"}:
                continue
            entry_attempt = entry.get("attempt")
            if entry.get("event") == "launched":
                if (
                        isinstance(entry_attempt, int)
                        and not isinstance(entry_attempt, bool)
                        and entry_attempt > 0):
                    attempt_keys.add((task.get("id"), entry_attempt))
                chars = entry.get("capsule_chars")
                if isinstance(chars, int) and not isinstance(chars, bool) and chars >= 0:
                    capsule_chars.append(chars)
            else:
                if entry.get("status") in {"failed", "blocked"}:
                    relevant_exits.append(entry)
                if (
                        isinstance(entry.get("warning"), str)
                        and POST_SUBMISSION_WARNING_RE.fullmatch(entry["warning"])):
                    warning_count += 1
                    warning_entries += 1
        if relevant_exits:
            for entry in relevant_exits:
                note = entry.get("note")
                code = note if isinstance(note, str) and REASON_CODE_RE.fullmatch(note) else "other"
                reasons[code] = reasons.get(code, 0) + 1
        elif status in {"failed", "blocked"}:
            note = task.get("last_note")
            code = note if isinstance(note, str) and REASON_CODE_RE.fullmatch(note) else "other"
            reasons[code] = reasons.get(code, 0) + 1
        if (
                not warning_entries
                and isinstance(task.get("warning"), str)
                and POST_SUBMISSION_WARNING_RE.fullmatch(task["warning"])):
            warning_count += 1

        task_id = task.get("id")
        if not isinstance(task_id, str) or not TASK_ID_RE.fullmatch(task_id):
            continue
        directory = (
            os.path.join(archive_dir(baton_dir), task_id + ".work")
            if archived_task else work_dir(baton_dir, task_id)
        )
        try:
            names = sorted(os.listdir(directory))
        except OSError:
            names = []
        for name in names:
            match = receipt_name.fullmatch(name)
            if not match:
                continue
            receipt_attempt = int(match.group(1))
            receipts = read_phase_receipts(
                os.path.join(directory, name), task_id, receipt_attempt,
            )
            if receipts is None:
                continue
            key = (task_id, receipt_attempt)
            attempt_keys.add(key)
            for phase in receipt_phases:
                if phase in receipts["phases"]:
                    receipt_phases[phase].add(key)

    say("Status counts:")
    for line in stats_count_lines(statuses):
        say(line)
    say("Attempts histogram:")
    for line in stats_count_lines(attempts, numeric=True):
        say(line)
    say("Failure/blocked reason codes:")
    for line in stats_count_lines(reasons):
        say(line)
    say("Capsule chars:")
    if capsule_chars:
        ordered_chars = sorted(capsule_chars)
        say("- min={} median={} max={}".format(
            ordered_chars[0], ordered_chars[(len(ordered_chars) - 1) // 2],
            ordered_chars[-1],
        ))
    else:
        say("- none recorded")
    say("Phase brief coverage (command-use evidence, not proof of attention):")
    denominator = len(attempt_keys)
    for phase in ("edit", "verify", "report"):
        say("- {}={}/{}".format(phase, len(receipt_phases[phase]), denominator))
    say("Post-submission warnings: {}".format(warning_count))


def dependency_cycles(tasks):
    by_id = {task.get("id"): task for task in tasks}
    visiting: list[str] = []
    visited = set()
    cycles = []

    def visit(task_id):
        if task_id in visiting:
            start = visiting.index(task_id)
            cycles.append([*visiting[start:], task_id])
            return
        if task_id in visited or task_id not in by_id:
            return
        visiting.append(task_id)
        for dependency in by_id[task_id].get("depends_on", []):
            if dependency in by_id:
                visit(dependency)
        visiting.pop()
        visited.add(task_id)

    for task_id in by_id:
        visit(task_id)
    return cycles


def task_validation_shape(task):
    """Validate task fields before any map, routing, or lifecycle consumer uses them."""
    task_id = task.get("id")
    prefix = (task_id + ": ") if isinstance(task_id, str) else "task state: "
    problems = []
    valid = {}

    try:
        validate_task_id(task_id)
        valid["id"] = True
    except ValueError as error:
        valid["id"] = False
        problems.append(prefix + str(error))

    status = task.get("status")
    valid["status"] = isinstance(status, str) and status in STATUSES
    if not valid["status"]:
        problems.append(prefix + "invalid status {!r}".format(status))

    for field in ("title", "tier", "created_at", "updated_at"):
        value = task.get(field)
        valid[field] = isinstance(value, str) and bool(value)
        if not valid[field]:
            problems.append(prefix + "{} must be non-empty text".format(field))
    if valid["title"] and (
            not is_single_line_text(task["title"])
            or any(ord(character) < 32 or 127 <= ord(character) <= 159
                   for character in task["title"])):
        valid["title"] = False
        problems.append(prefix + "title must be single-line text without control characters")

    attempt = task.get("attempt")
    valid["attempt"] = (
        not isinstance(attempt, bool) and isinstance(attempt, int) and attempt >= 1
    )
    if not valid["attempt"]:
        problems.append(prefix + "attempt must be a positive integer")

    history_problems = task_history_problems(task, prefix)
    valid["history"] = not history_problems
    problems.extend(history_problems)

    scopes = task.get("scope")
    valid["scope"] = isinstance(scopes, list) and all(
        isinstance(scope, str) for scope in scopes
    )
    if not valid["scope"]:
        problems.append(prefix + "scope must be a list of text")
    else:
        try:
            if normalize_scopes(scopes) != scopes:
                valid["scope"] = False
                problems.append(prefix + "scope is not canonical")
        except ValueError as error:
            valid["scope"] = False
            problems.append(prefix + str(error))

    dependencies = task.get("depends_on")
    valid["depends_on"] = isinstance(dependencies, list) and all(
        isinstance(dependency, str) for dependency in dependencies
    )
    if not valid["depends_on"]:
        problems.append(prefix + "depends_on must be a list of task ids")

    valid["problems"] = problems
    return valid


def task_problems(
        baton_dir, task, shape, known_tasks, known_shapes, memory_entries,
        config=None, tier_cache=None, archived=False):
    problems = list(shape["problems"])
    task_id = task.get("id")
    prefix = (task_id + ": ") if shape["id"] else "task state: "
    tier = None
    report_requires_sections = False
    if config is not None and shape["tier"]:
        try:
            tier = configured_task_tier(config, task, tier_cache)
        except ValueError as error:
            problems.append(prefix + str(error))
    if config is not None:
        try:
            report_requires_sections = configured_report_requires_sections(config)
        except ValueError:
            pass
    state_directory = archive_dir(baton_dir) if archived else tasks_dir(baton_dir)
    if shape["id"] and not os.path.exists(os.path.join(state_directory, task_id + ".json")):
        problems.append(prefix + "state filename does not match its id")
    if archived and shape["status"] and task["status"] not in ("done", "cancelled"):
        problems.append(prefix + "archived task status must be done or cancelled")
    dependencies = task.get("depends_on")
    if shape["depends_on"]:
        if len(dependencies) != len(set(dependencies)):
            problems.append(prefix + "duplicate dependencies")
        if shape["id"] and task_id in dependencies:
            problems.append(prefix + "self dependency")
        for dependency in dependencies:
            if dependency not in known_tasks:
                problems.append(prefix + "unknown dependency {}".format(dependency))
            elif not known_shapes[dependency]["status"]:
                problems.append(prefix + "dependency {} has invalid status".format(dependency))
            elif known_tasks[dependency]["status"] == "cancelled":
                problems.append(prefix + "cancelled dependency {}".format(dependency))
    runner = task.get("runner")
    if shape["status"] and task["status"] == "running":
        if not isinstance(runner, dict):
            problems.append(prefix + "running task needs runner metadata")
        else:
            if not isinstance(runner.get("lease"), str) or not runner["lease"]:
                problems.append(prefix + "running task lease is missing")
            if not pid_alive(runner.get("pid")):
                problems.append(prefix + "running worker is stale")
    elif shape["status"] and runner:
        problems.append(prefix + "runner exists while task is not running")
    if (not archived and shape["id"] and shape["status"] and shape["attempt"]
            and task["status"] == "needs_review"):
        report = report_path(baton_dir, task_id, task["attempt"])
        if not report_is_ready(report):
            problems.append(prefix + "review report is missing or invalid")
        for problem in report_gate_problems(
                report, "needs_review", report_requires_sections):
            problems.append(prefix + problem)
        if shape["history"]:
            try:
                review_evidence_details(baton_dir, task)
            except (OSError, UnicodeDecodeError, ValueError, json.JSONDecodeError) as error:
                problems.append(prefix + str(error))
    elif (
            shape["id"] and shape["status"] and shape["attempt"]
            and task["status"] == "done" and shape["history"]
            and latest_worker_exit(task).get("result_digest") is not None
    ):
        try:
            review_evidence_details(baton_dir, task, archived=archived)
        except (OSError, UnicodeDecodeError, ValueError, json.JSONDecodeError) as error:
            problems.append(prefix + str(error))
    violations = task.get("scope_violations")
    if violations:
        if shape["status"] and task["status"] not in ("blocked", "failed"):
            problems.append(prefix + "scope violations require blocked or failed status")
        if not task.get("scope_baseline"):
            problems.append(prefix + "scope violation baseline is missing")
    elif task.get("scope_baseline"):
        problems.append(prefix + "scope baseline exists without violations")
    if (not archived and shape["id"] and shape["status"] and shape["title"]
            and shape["scope"] and task["status"] == "queued" and tier is not None):
        spec_path = task_md_path(baton_dir, task_id)
        if os.path.exists(spec_path):
            try:
                with open(spec_path, encoding="utf-8") as source:
                    compile_context_capsule(
                        task, source.read(), memory_entries, tier["capsule_max_chars"],
                    )
            except (OSError, UnicodeDecodeError, ValueError) as error:
                problems.append(str(error))
    return problems


def archive_task_id_is_valid(task_id):
    return (
        isinstance(task_id, str)
        and TASK_ID_RE.fullmatch(task_id) is not None
        and int(task_id[1:task_id.index("-")]) > 0
    )


def task_requires_work_artifact(task):
    history = task.get("history")
    return isinstance(history, list) and any(
        isinstance(entry, dict) and entry.get("event") == "launched"
        for entry in history
    )


def task_requires_spec_artifact(task):
    history = task.get("history")
