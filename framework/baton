            if task["status"] not in WORKER_FINAL:
                die("{} is {}; it cannot be returned".format(task["id"], task["status"]))
            violations = task.get("scope_violations", [])
            if violations:
                baseline = task.get("scope_baseline")
                if not baseline:
                    die("scope violation baseline is missing; run .baton/baton validate")
                root = project_root(baton_dir)
                require_git_root(root)
                current_tree = git_snapshot(root)
                changed = set(git_changed_paths(root, baseline, current_tree))
                unresolved = [path for path in violations if path in changed]
                if unresolved:
                    die(
                        "restore scope-violating paths before returning: "
                        + ", ".join(unresolved)
                    )
            previous_attempt = task.get("attempt", 1)
            publish_retry_context(
                baton_dir, task["id"], "return", previous_attempt, "Review feedback",
                "- attempt %d: %s" % (previous_attempt, args.reason),
            )
            invalidate_review_token(baton_dir, task["id"])
            task["status"] = "queued"
            task["attempt"] = previous_attempt + 1
            task.pop("runner", None)
            task.pop("scope_violations", None)
            task.pop("scope_baseline", None)
            task.pop("last_note", None)
            record(task, "returned", reason=args.reason)
            save_task(baton_dir, task)
    say("%s returned for attempt %d" % (task["id"], task["attempt"]))


