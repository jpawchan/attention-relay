def configured_tier_names(config):
    tiers = config.get("tiers", {})
    if not isinstance(tiers, dict):
        raise ValueError("tiers must be a table")
    if any(not isinstance(name, str) or not name.strip() for name in tiers):
        raise ValueError("tier name must be non-blank")
    if "default" in tiers:
        raise ValueError("tier name 'default' is reserved")
    return sorted(tiers)


def validated_display_metadata(value):
    """Validate and sanitize bounded operator-authored worker display metadata."""
    if value is None:
        return {}
    if not isinstance(value, dict):
        raise ValueError("tier display metadata must be a table")
    unknown = sorted(set(value) - set(DISPLAY_FIELDS))
    if unknown:
        raise ValueError("unknown tier display metadata: " + ", ".join(unknown))
    metadata = {}
    for name in DISPLAY_FIELDS:
        if name not in value:
            continue
        item = value[name]
        if not isinstance(item, str) or not item.strip():
            raise ValueError("tier display {} must be non-blank text".format(name))
        if len(item) > DISPLAY_VALUE_MAX_CHARS:
            raise ValueError(
                "tier display {} exceeds {} characters".format(
                    name, DISPLAY_VALUE_MAX_CHARS,
                )
            )
        if any(ord(character) < 32 or 127 <= ord(character) <= 159 for character in item):
            raise ValueError("tier display {} must not contain control characters".format(name))
        if re.search(r"(?<![A-Za-z0-9])--?[A-Za-z0-9]", item):
            raise ValueError("tier display {} must not contain command flags".format(name))
        metadata[name] = " ".join(sanitize_log_text(item).split())
    return metadata


def worker_display_label(tier):
    metadata = tier.get("display", {})
    if not metadata:
        return "unlabeled worker"
    label = "; ".join(
        "{}={}".format(name, metadata[name])
        for name in DISPLAY_FIELDS if metadata.get(name)
    )
    return flatten_bounded_text(label, WORKER_LABEL_MAX_CHARS) or "unlabeled worker"


def validate_worker_executable(template, root):
    """Validate a command template and verify its executable without running it."""
    argv = validate_worker_template(template)
    executable = argv[0]
    if os.path.sep in executable:
        candidate = executable if os.path.isabs(executable) else os.path.join(root, executable)
        if not os.path.isfile(candidate) or not os.access(candidate, os.X_OK):
            raise ValueError("worker executable not found: {}".format(executable))
    elif not shutil.which(executable):
        raise ValueError("worker executable not found: {}".format(executable))
    return argv


def conventional_level_names(config, root=None):
    configured = []
    missing = []
    for name in CONVENTIONAL_LEVELS:
        try:
            tier = configured_tier(config, name)
            if root is not None:
                validate_worker_executable(tier["command"], root)
        except ValueError:
            missing.append(name)
        else:
            configured.append(name)
    return configured, missing


