def sha256_regular_file(path):
    """Return a streaming SHA-256 hex digest for a non-symlink regular file."""
    if os.path.islink(path):
        raise OSError("not a regular file: {}".format(path))
    flags = os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0)
    descriptor = os.open(path, flags)
    try:
        if not stat.S_ISREG(os.fstat(descriptor).st_mode):
            raise OSError("not a regular file: {}".format(path))
        digest = hashlib.sha256()
        with os.fdopen(descriptor, "rb") as source:
            descriptor = None
            while True:
                chunk = source.read(1024 * 1024)
                if not chunk:
                    break
                digest.update(chunk)
        return digest.hexdigest()
    finally:
        if descriptor is not None:
            os.close(descriptor)


def review_result_schema_problems(result):
    """Return strict worker-result schema problems without trusting its values."""
    required = {"status", "note", "at", "lease", "changed_paths"}
    if not isinstance(result, dict):
        return ["review result must contain a JSON object"]
    problems = []
    if set(result) != required:
        problems.append(
            "review result must contain exactly these fields: "
            "status, note, at, lease, changed_paths"
        )
    if not isinstance(result.get("status"), str) or result.get("status") not in WORKER_FINAL:
        problems.append("review result status is invalid")
    if not isinstance(result.get("note"), str):
        problems.append("review result note must be text")
    if not is_utc_timestamp(result.get("at")):
        problems.append("review result at must be a valid UTC timestamp")
    if not isinstance(result.get("lease"), str) or not result.get("lease"):
        problems.append("review result lease must be non-empty text")
    if worker_changed_paths(result.get("changed_paths")) is None:
        problems.append("review result changed_paths are missing or invalid")
    return problems


def review_history_shape_problems(task):
    """Return lifecycle history shape problems before entries are traversed."""
    history = task.get("history")
    if not isinstance(history, list):
        return ["review lifecycle history must be a list"]
    return [
        "review lifecycle history entry {} must be an object".format(index)
        for index, entry in enumerate(history) if not isinstance(entry, dict)
    ]


def review_lifecycle_details(task, result, result_hash):
    """Bind a valid result object to one unambiguous current-attempt lifecycle."""
    attempt = task.get("attempt", 1)
    problems = review_history_shape_problems(task)
    if problems:
        return problems, {}, [], []
    history = task["history"]
    launches = [
        (index, entry) for index, entry in enumerate(history)
        if entry.get("event") == "launched" and entry.get("attempt") == attempt
    ]
    if len(launches) != 1:
        problems.append(
            "review lifecycle must contain exactly one launch for task attempt {}"
            .format(attempt)
        )
        return problems, {}, [], []
    launch_index, launch = launches[0]
    all_launch_indices = [
        index for index, entry in enumerate(history)
        if entry.get("event") == "launched"
    ]
    if all_launch_indices and launch_index != all_launch_indices[-1]:
        problems.append("review lifecycle current-attempt launch is not the latest launch")

    exits = [
        (index, entry) for index, entry in enumerate(history)
        if index > launch_index and entry.get("event") == "worker_exited"
    ]
    if len(exits) != 1:
        problems.append(
            "review lifecycle must contain exactly one worker exit after its launch"
        )
        return problems, {}, [], []
    exit_index, worker_exit = exits[0]
    latest_exit_index = next(
        (index for index in range(len(history) - 1, -1, -1)
         if history[index].get("event") == "worker_exited"),
        None,
    )
    if exit_index != latest_exit_index:
        problems.append("review lifecycle current-attempt exit is not the latest worker exit")
    if "attempt" in worker_exit and worker_exit.get("attempt") != attempt:
        problems.append("review lifecycle worker exit attempt does not match task attempt")

    lease = launch.get("lease")
    if not isinstance(lease, str) or not lease:
        problems.append("review lifecycle launch lease is missing or invalid")
    elif result["lease"] != lease:
        problems.append("review result lease does not match launch")
    if result["status"] != worker_exit.get("status"):
        problems.append("review result status does not match worker exit")
    if not isinstance(worker_exit.get("note"), str):
        problems.append("review lifecycle worker exit note is invalid")
    elif result["note"] != worker_exit["note"]:
        problems.append("review result note does not match worker exit")

    declared = worker_changed_paths(worker_exit.get("declared_paths"))
    if declared is None:
        problems.append("review lifecycle worker exit declared_paths are invalid")
        declared = []
    elif result["changed_paths"] != declared:
        problems.append(
            "review result changed_paths do not match worker exit declared_paths"
        )
    if (
            "observed_paths" not in worker_exit
            and not declared
    ):
        # Early finalized no-change records omitted this redundant empty field.
        observed = []
    else:
        observed = worker_changed_paths(worker_exit.get("observed_paths"))
    if observed is None:
        problems.append("review observed changed paths are invalid")
        observed = []
    elif (
            len(declared) != len(observed)
            or {path.casefold() for path in declared}
            != {path.casefold() for path in observed}):
        problems.append("review declared and observed changed paths do not match")

    if not is_utc_timestamp(launch.get("at")):
        problems.append("review lifecycle launch timestamp is invalid")
    if not is_utc_timestamp(worker_exit.get("at")):
        problems.append("review lifecycle worker exit timestamp is invalid")
    if (
            is_utc_timestamp(launch.get("at"))
            and is_utc_timestamp(worker_exit.get("at"))
            and not (launch["at"] <= result["at"] <= worker_exit["at"])
    ):
        problems.append("review result timestamp is outside its lifecycle")

    finalized_digest = worker_exit.get("result_digest")
    if finalized_digest is not None:
        if not isinstance(finalized_digest, str) or not re.fullmatch(
                r"sha256:[0-9a-f]{64}", finalized_digest):
            problems.append("review lifecycle result digest is invalid")
        elif finalized_digest != "sha256:" + result_hash:
            problems.append("review result changed after finalization")
    return problems, worker_exit, declared, observed


def review_evidence_details(baton_dir, task, archived=False):
    """Read and validate the immutable artifact details needed for review."""
    attempt = task.get("attempt", 1)
    if archived:
        directory = os.path.join(archive_dir(baton_dir), task["id"] + ".work")
        report = os.path.join(directory, "attempt-%d.report.md" % attempt)
        result_file = os.path.join(directory, "attempt-%d.result.json" % attempt)
        diff = os.path.join(directory, "attempt-%d.diff" % attempt)
    else:
        report = report_path(baton_dir, task["id"], attempt)
        result_file = result_path(baton_dir, task["id"], attempt)
        diff = diff_path(baton_dir, task["id"], attempt)
    paths = {"report": report, "result": result_file, "diff": diff}
    hashes = {}
    problems = []
    for name, path in paths.items():
        try:
            hashes[name] = sha256_regular_file(path)
        except OSError as error:
            problems.append("review {} is missing or invalid: {}".format(name, error))

    result = None
    if "result" in hashes:
        try:
            result = read_json(result_file)
        except (OSError, UnicodeDecodeError, json.JSONDecodeError) as error:
            problems.append("review result JSON is invalid: {}".format(error))
        else:
            try:
                if sha256_regular_file(result_file) != hashes["result"]:
                    problems.append("review result changed while its manifest was built")
            except OSError as error:
                problems.append("review result is missing or invalid: {}".format(error))

    declared = None
    observed = None
    history_problems = review_history_shape_problems(task)
    problems.extend(history_problems)
    if result is not None:
        schema_problems = review_result_schema_problems(result)
        problems.extend(schema_problems)
        if not schema_problems and not history_problems:
            lifecycle_problems, _worker_exit, declared, observed = (
                review_lifecycle_details(task, result, hashes["result"])
            )
            problems.extend(lifecycle_problems)
        elif not history_problems:
            worker_exit = latest_worker_exit(task)
            legacy_empty_observed = (
                "observed_paths" not in worker_exit
                and worker_exit.get("declared_paths") == []
            )
            if (
                    not legacy_empty_observed
                    and worker_changed_paths(worker_exit.get("observed_paths")) is None
            ):
                problems.append("review observed changed paths are invalid")
    if problems:
        raise ValueError("; ".join(problems))
    return {
        "report": "sha256:" + hashes["report"],
        "result": "sha256:" + hashes["result"],
        "diff": "sha256:" + hashes["diff"],
        "declared": sorted(declared),
        "observed": sorted(observed),
    }


def build_review_evidence_manifest(baton_dir, task, capsule):
    """Build the immutable evidence description used by the review accept gate."""
    evidence = review_evidence_details(baton_dir, task)
    evidence["capsule"] = "sha256:" + hashlib.sha256(
        capsule.encode("utf-8")
    ).hexdigest()
    return {
        "task_id": task["id"],
        "attempt": task.get("attempt", 1),
        "evidence": evidence,
    }


