def record(task, event, **details):
    entry = {"at": now(), "event": event}
    entry.update(details)
    task.setdefault("history", []).append(entry)


def load_tasks_from(directory, validate_history=True):
    tasks: list[dict] = []
    if not os.path.isdir(directory):
        return tasks
    for name in sorted(os.listdir(directory)):
        if name.endswith(".json"):
            path = os.path.join(directory, name)
            try:
                task = read_json(path)
                if not isinstance(task, dict):
                    raise ValueError(
                        "task state {} must contain a JSON object".format(path)
                    )
                if validate_history:
                    require_loaded_task_shape(task, path)
                tasks.append(task)
            except (OSError, UnicodeDecodeError, json.JSONDecodeError) as error:
                raise ValueError(
                    "cannot read task state {}: {}".format(path, error)
                ) from error
    return tasks


def load_all_tasks(baton_dir, validate_history=True):
