REPORT_SECTIONS = ("Result", "Changes", "Verification", "Decisions and risks")


def commonmark_fence_state(line, state):
    """Return fenced-code state after one line under CommonMark fence rules."""
    indent = len(line) - len(line.lstrip(" "))
    candidate = line[indent:] if indent <= 3 else ""
    if state is not None:
        character, length = state
        run_length = len(candidate) - len(candidate.lstrip(character))
        if (
                run_length >= length
                and candidate[run_length:].strip(" \t") == ""):
            return None
        return state
    opening = re.fullmatch(r"(`{3,}|~{3,})(.*)", candidate)
    if opening and not (
            opening.group(1)[0] == "`" and "`" in opening.group(2)):
        return opening.group(1)[0], len(opening.group(1))
    return None


def report_section_problems(text, expected_status):
    """Return problems with the worker report template, without changing state."""
    sections = {name: None for name in REPORT_SECTIONS}
    current = None
    fence_state = None
    for line in text.splitlines():
        previous_fence_state = fence_state
        fence_state = commonmark_fence_state(line, fence_state)
        if previous_fence_state is None and fence_state is not None:
            continue
        elif previous_fence_state is not None:
            if fence_state is None:
                continue
        elif line == "##" or line.startswith("## "):
            name = line[3:] if line.startswith("## ") else ""
            if name in sections:
                if sections[name] is None:
                    sections[name] = []
                current = name
            else:
                current = None
            continue
        if current is not None:
            sections[current].append(line)

    problems = []
    for name in REPORT_SECTIONS:
        if sections[name] is None:
            problems.append("missing required report section `## {}`".format(name))
    for name in REPORT_SECTIONS[:3]:
        body = sections[name]
        if body is not None and not any(line.strip() for line in body):
            problems.append("report section `## {}` has an empty body".format(name))
    result = sections["Result"]
    if result is not None:
        first = next((line.strip() for line in result if line.strip()), None)
        if first is not None and first != expected_status:
            problems.append(
                "report section `## Result` starts with {!r}, not submitted status {!r}".format(
                    first, expected_status,
                )
            )
    return problems


def read_report_for_section_gate(path):
    """Read a non-symlink regular report as UTF-8, returning text or one problem."""
    if not os.path.lexists(path):
        return None, "report file is missing"
    if os.path.islink(path):
        return None, "report file is not a regular file"
    try:
        descriptor = os.open(path, os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0))
    except OSError:
        return None, "report file is unreadable"
    try:
        if not stat.S_ISREG(os.fstat(descriptor).st_mode):
            return None, "report file is not a regular file"
        with os.fdopen(descriptor, "rb") as source:
            descriptor = None
            data = source.read()
    except OSError:
        return None, "report file is unreadable"
    finally:
        if descriptor is not None:
            os.close(descriptor)
    try:
        return data.decode("utf-8"), None
    except UnicodeDecodeError:
        return None, "report file is not valid UTF-8"


def report_gate_problems(path, expected_status, requires_sections):
    """Return enabled report-gate problems for one final report artifact."""
    if not requires_sections:
        return [] if report_is_ready(path) else ["report file is missing or invalid"]
    report_text, read_problem = read_report_for_section_gate(path)
    if read_problem:
        return [read_problem]
    return report_section_problems(report_text, expected_status)


def read_json(path):
    if os.path.islink(path) or not os.path.isfile(path):
        raise OSError("not a regular JSON file: {}".format(path))
    with open(path, encoding="utf-8") as source:
        text = source.read()
    try:
        return json.loads(text)
    except json.JSONDecodeError:
        raise
    except ValueError as error:
        raise json.JSONDecodeError(str(error), text, 0) from error


def task_history_problems(task, prefix=""):
    """Return structural history problems without invoking lifecycle consumers."""
    history = task.get("history")
    if not isinstance(history, list):
        return [prefix + "history must be a list"]
    problems = []
    for index, entry in enumerate(history):
        entry_prefix = "{}history entry {} ".format(prefix, index)
        if not isinstance(entry, dict):
            problems.append(entry_prefix + "must be an object")
            continue
        for field in ("at", "event"):
            if not isinstance(entry.get(field), str) or not entry[field]:
                problems.append(entry_prefix + "{} must be non-empty text".format(field))
    return problems


def require_loaded_task_shape(task, path, validate_history_fields=False):
    """Reject task shapes that ordinary lifecycle consumers cannot safely read."""
    if not isinstance(task, dict):
        raise ValueError("task state {} must contain a JSON object".format(path))
    history = task.get("history")
    if not isinstance(history, list):
        raise ValueError("task state {} history must be a list".format(path))
    for index, entry in enumerate(history):
        if not isinstance(entry, dict):
            raise ValueError(
                "task state {} history entry {} must be an object".format(path, index)
            )
    if validate_history_fields:
        problems = task_history_problems(task)
        if problems:
            raise ValueError("task state {} {}".format(path, problems[0]))
    return task


def load_task(baton_dir, task_id, include_archive=False):
    path = task_json_path(baton_dir, task_id)
    if not os.path.exists(path) and include_archive:
        path = os.path.join(archive_dir(baton_dir), task_id + ".json")
    if not os.path.exists(path):
        die("no such task: {}".format(task_id))
    try:
        task = read_json(path)
    except (OSError, UnicodeDecodeError, json.JSONDecodeError) as error:
        die("cannot read task {}: {}".format(task_id, error))
    try:
        return require_loaded_task_shape(task, path)
    except ValueError as error:
        die("cannot read task {}: {}".format(task_id, error))


